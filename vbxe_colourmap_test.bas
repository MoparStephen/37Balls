100 REM =====================================================
110 REM  VBXE ATTRIBUTE COLOUR-MAP TEST BED - Turbo-BASIC XL
120 REM  Ports the VBXE init from init_vbxe.asm: detects VBXE,
130 REM  clears VBXE RAM, loads the XDLs (xdl.asm) and the
140 REM  colour-map BCBs (bcbs.asm) into VBXE RAM at the same
150 REM  addresses demo.asm uses, then turns on the XDL/XCOLOR
160 REM  overlay so the attribute map can be edited live from
170 REM  BASIC while running on real hardware.
180 REM
190 REM  PROCs take no arguments (Turbo-BASIC XL PROC/EXEC does
200 REM  not support parameter lists - all variables are global
210 REM  with no scoping). Set the input variables, then EXEC.
220 REM  After RUN completes, use direct mode to experiment:
230 REM    ROWNUM=r:COLNUM=c:CIDX=i:CPRI=p:EXEC POKECELL
240 REM    ADDR=a:BYTEVAL=v:EXEC PUTBYTE
250 REM    ADDR=a:EXEC GETBYTE : PRINT GBRES
255 REM    EXEC GENERATECOLOURMAP restores the demo's default 208-colour map
260 REM  ROW is 0-239, COL is 0-79. PRIORITYBYTE is normally $50
270 REM  (set by PrimeColourMap). ADDRESS is any linear VBXE
280 REM  address $00000-$7FFFF.
290 REM  POKE VBASE+VIDCTL,0 turns the overlay back off.
300 REM =====================================================
310 REM
320 REM ---- VBXE register offsets (add to VBASE) ----
330 VIDCTL=$40:XDL0=$41:XDL1=$42:XDL2=$43
340 BLADR0=$50:BLADR1=$51:BLADR2=$52:BLBUSY=$53
345 CSEL=$44:PSEL=$45:VCR=$46:VCG=$47:VCB=$48
350 MACTL=$5E:MABSEL=$5F
360 REM
370 REM ---- VBXE memory-map constants (linear VBXE addresses) ----
380 XDLADR=$400:REM XDL_Attribute (XDL_Normal follows at +$15=$415)
390 XDLNORM=XDLADR+$15
400 BCBADR=$500:REM BLT_CLEAR
410 CM1ADR=BCBADR+$15:REM BLT_SETUP_CMAP_1
420 CM2ADR=CM1ADR+$15:REM BLT_SETUP_CMAP_2
425 BALLADR=CM2ADR+$15:REM BLT_BALL
427 PALADR=$1000:REM bank 1 - Palette.pal (768 bytes: 256 RGB triplets)
430 CMAPBASE=393216:REM $60000 start of the attribute colour map (>$FFFF, must stay decimal)
440 CMAPROW=$28:REM bytes per screen line (10 cells * 4 bytes)
450 WINDOW=$6000:REM CPU-side address the VBXE window maps to
455 DIM COLTAB(239):REM per-object colour table (Generate_Colour_Map's $0600 table)
457 REM ---- ANTIC/OS shadow registers (plain CPU addresses, no VBXE window) ----
458 SDMCTL=$22F:SDLSTL=$230:REM SDLSTL+1 is the display list pointer high byte
459 DIM DLSTR$(514):REM reserves CPU RAM for the custom display list (259 bytes + slack for page-alignment)
460 DIM TILESTR$(520):REM reserves CPU RAM for the Fuji tile - OS-agnostic stand-in for SAVMSC
465 GOTO 9000
470 REM
1000 PROC DetectVBXE
1010 VBASE=$D600:REM try VBXE based at $D600 (VIDCTL @ $D640)
1020 POKE VBASE+VIDCTL,0:REM Use 5 when using VBXE.SYS via SDX
1030 IF PEEK(VBASE+VIDCTL)=$10 THEN FOUND=1:ENDPROC
1040 VBASE=$D700:REM try VBXE based at $D700 (VIDCTL @ $D740)
1050 POKE VBASE+VIDCTL,0:REM Use 5 when using VBXE.SYS via SDX
1060 IF PEEK(VBASE+VIDCTL)=$10 THEN FOUND=1:ENDPROC
1070 FOUND=0
1080 ENDPROC
1082 REM SETUPVBXE - points the CPU window at VBXE_WINDOW, size 4k (init_vbxe.asm clear_vbxe)
1084 PROC SETUPVBXE
1085 PRINT "SETTING UP VBXE WINDOW"
1086 POKE VBASE+MACTL,INT(WINDOW/$100)+8
1088 ENDPROC
1090 REM
1100 REM PUTBYTE - in: ADDR,BYTEVAL - writes BYTEVAL to VBXE address ADDR
1110 PROC PUTBYTE
1120 BANK=INT(ADDR/$1000)
1130 OFS=ADDR-BANK*$1000
1140 POKE VBASE+MABSEL,BANK+$80:REM ? HEX$(VBASE+MABSEL),HEX$(BANK+$80)
1150 POKE WINDOW+OFS,BYTEVAL:REM ? HEX$(WINDOW+OFS),HEX$(BYTEVAL)
1155 POKE VBASE+MABSEL,0:REM Close the window - don't leave it mapped over live RAM
1160 ENDPROC
1170 REM
1180 REM GETBYTE - in: ADDR - out: GBRES - reads VBXE address ADDR
1190 PROC GETBYTE
1200 BANK=INT(ADDR/$1000)
1210 OFS=ADDR-BANK*$1000
1220 POKE VBASE+MABSEL,BANK+$80
1230 GBRES=PEEK(WINDOW+OFS)
1235 POKE VBASE+MABSEL,0:REM Close the window - don't leave it mapped over live RAM
1240 ENDPROC
1250 REM
1260 REM KICKBLIT - in: ADDR - fires the blitter on the BCB at VBXE address ADDR
1270 PROC KICKBLIT
1280 REPEAT
1290 UNTIL PEEK(VBASE+BLBUSY)=0
1300 POKE VBASE+BLADR0,ADDR-INT(ADDR/$100)*$100
1310 POKE VBASE+BLADR1,INT(ADDR/$100)-INT(ADDR/65536)*$100
1320 POKE VBASE+BLADR2,INT(ADDR/65536)
1330 POKE VBASE+BLBUSY,$01
1340 REPEAT
1350 UNTIL PEEK(VBASE+BLBUSY)=0
1360 ENDPROC
1370 REM
1380 PROC LOADXDL
1385 PRINT "LOADING XDL"
1390 RESTORE 5000
1400 FOR I=0 TO $20
1410 READ V
1420 ADDR=XDLADR+I:BYTEVAL=V:EXEC PUTBYTE
1430 NEXT I
1440 ENDPROC
1450 REM
1460 PROC LOADBCB
1465 PRINT "LOADING BCBs"
1470 RESTORE 5100
1480 FOR I=0 TO $14
1490 READ V
1500 ADDR=BCBADR+I:BYTEVAL=V:EXEC PUTBYTE
1510 NEXT I
1520 RESTORE 5200
1530 FOR I=0 TO $14
1540 READ V
1550 ADDR=CM1ADR+I:BYTEVAL=V:EXEC PUTBYTE
1560 NEXT I
1570 RESTORE 5300
1580 FOR I=0 TO $14
1590 READ V
1600 ADDR=CM2ADR+I:BYTEVAL=V:EXEC PUTBYTE
1610 NEXT I
1612 RESTORE 5400
1614 FOR I=0 TO $14
1616 READ V
1618 ADDR=BALLADR+I:BYTEVAL=V:EXEC PUTBYTE
1619 NEXT I
1620 ENDPROC
1630 REM
1640 PROC CLEARVBXE
1645 PRINT "CLEARING VBXE RAM"
1650 ADDR=BCBADR:EXEC KICKBLIT
1660 ENDPROC
1670 REM
1680 PROC PRIMECOLOURMAP
1685 PRINT "PRIMING COLOUR MAP"
1690 ADDR=CM1ADR:EXEC KICKBLIT
1700 ENDPROC
1710 REM
1720 PROC ACTIVATECOLOURMAP
1725 PRINT "COLOUR MAP OVERLAY ON"
1730 POKE VBASE+XDL0,XDLADR-INT(XDLADR/$100)*$100
1740 POKE VBASE+XDL1,INT(XDLADR/$100)-INT(XDLADR/65536)*$100
1750 POKE VBASE+XDL2,INT(XDLADR/65536)
1760 POKE VBASE+VIDCTL,$03
1770 ENDPROC
1780 REM
1790 PROC ACTIVATENORMAL
1795 PRINT "COLOUR MAP OVERLAY OFF"
1800 POKE VBASE+XDL0,XDLNORM-INT(XDLNORM/$100)*$100
1810 POKE VBASE+XDL1,INT(XDLNORM/$100)-INT(XDLNORM/65536)*$100
1820 POKE VBASE+XDL2,INT(XDLNORM/65536)
1830 POKE VBASE+VIDCTL,$01
1840 ENDPROC
1850 REM
1860 REM POKECELL - in: ROWNUM,COLNUM,CIDX,CPRI - writes one colour-map cell
1870 PROC POKECELL
1875 PRINT "POKECELL ROW=";ROWNUM;" COL=";COLNUM;" IDX=";CIDX;" PRI=";CPRI
1880 CADR=CMAPBASE+ROWNUM*CMAPROW+COLNUM*$04
1890 ADDR=CADR+1:BYTEVAL=CIDX:EXEC PUTBYTE
1900 ADDR=CADR+3:BYTEVAL=CPRI:EXEC PUTBYTE
1910 ENDPROC
1920 REM
1922 REM LOADPALETTE - streams Palette.pal (768 bytes) into VBXE bank 1
1924 PROC LOADPALETTE
1925 PRINT "LOADING PALETTE"
1926 POKE VBASE+MABSEL,INT(PALADR/$1000)+$80
1928 CLOSE :OPEN #1,4,0,"D:PALETTE.PAL"
1930 BGET #1,WINDOW,768
1932 CLOSE #1
1933 POKE VBASE+MABSEL,0:REM Close the window - don't leave it mapped over live RAM
1934 ENDPROC
1936 REM
1938 REM SETPALETTE1 - pushes VBXE bank 1's 256 RGB triplets into palette #1
1940 REM (ports VBXE_SetPalette2 from vbxe_min.asm)
1942 PROC SETPALETTE1
1943 PRINT "SETTING PALETTE 1"
1944 POKE VBASE+PSEL,1
1946 POKE VBASE+CSEL,0
1948 FOR N=0 TO 767
1950 ADDR=PALADR+N:EXEC GETBYTE
1952 IF N-INT(N/3)*3=0 THEN POKE VBASE+VCR,GBRES
1954 IF N-INT(N/3)*3=1 THEN POKE VBASE+VCG,GBRES
1956 IF N-INT(N/3)*3=2 THEN POKE VBASE+VCB,GBRES
1958 NEXT N
1960 ENDPROC
1962 REM
2000 REM
2010 PROC DRAWFUJIS
2025 PRINT "DRAWING BACKGROUND"
2030 POKE $02C5,$08:REM lda #$08:sta COLOR1
2040 POKE $02C6,$00:REM lda #$00:sta COLOR2
2050 SAVMSC=ADR(TILESTR$):SIZE=$0208
2080 CLOSE :OPEN #1,4,0,"D:FUJIMONO.RAW"
2090 BGET #1,SAVMSC,SIZE
2120 ENDPROC
2130 REM
2140 REM SETUPDISPLAYLIST - builds a 240-line repeating Mode F display list that
2150 REM re-uses SAVMSC (drawn by DRAWFUJIS) as a repeating LMS tile, then points
2160 REM ANTIC at it (Setup_DisplayList + Display_List in demo.asm). Must run
2165 REM after DRAWFUJIS since it reuses that SAVMSC bitmap.
2170 PROC SETUPDISPLAYLIST
2172 PRINT "SETTING UP DISPLAY LIST"
2174 DLBASE=INT((ADR(DLSTR$)+255)/256)*256:SCRLO=SAVMSC-INT(SAVMSC/256)*256:SCRHI=INT(SAVMSC/256)
2176 POKE DLBASE,0:POKE DLBASE+1,$4F:POKE DLBASE+2,SCRLO:POKE DLBASE+3,SCRHI:OFS2=4
2178 FOR G=1 TO 15
2180 FOR K=1 TO 12:POKE DLBASE+OFS2,$0F:OFS2=OFS2+1:NEXT K
2182 POKE DLBASE+OFS2,$10:OFS2=OFS2+1:POKE DLBASE+OFS2,$4F:OFS2=OFS2+1
2184 POKE DLBASE+OFS2,SCRLO:OFS2=OFS2+1:POKE DLBASE+OFS2,SCRHI:OFS2=OFS2+1
2186 NEXT G
2188 FOR K=1 TO 12:POKE DLBASE+OFS2,$0F:OFS2=OFS2+1:NEXT K
2190 DLLO=DLBASE-INT(DLBASE/256)*256:DLHI=INT(DLBASE/256)
2192 POKE DLBASE+OFS2,$41:POKE DLBASE+OFS2+1,DLLO:POKE DLBASE+OFS2+2,DLHI
2194 POKE SDMCTL,0:POKE SDLSTL,DLLO:POKE SDLSTL+1,DLHI:POKE SDMCTL,$22:REM $22 = normal playfield width, ANTIC DMA on
2196 ENDPROC
2198 REM
2200 REM GENERATECOLOURMAP - builds COLTAB (16 objects * 15 rows, rows 0 and
2210 REM 14 blank, rows 1-13 an incrementing accumulator = 208 colours),
2220 REM then primes the palette/priority bytes and paints COLTAB into the
2230 REM colour map (Generate_Colour_Map in demo.asm)
2240 PROC GENERATECOLOURMAP
2245 PRINT "GENERATING COLOUR MAP"
2250 REG1=1
2260 IDX=0
2270 FOR OBJ=0 TO 15
2280 FOR CROW=0 TO 14
2290 CVAL=0
2300 IF CROW>0 AND CROW<14 THEN CVAL=REG1:REG1=REG1+1
2310 COLTAB(IDX)=CVAL
2320 IDX=IDX+1
2330 NEXT CROW
2340 NEXT OBJ
2350 EXEC PRIMECOLOURMAP
2360 EXEC SETUPCOLOURS
2370 ENDPROC
2380 REM
2390 REM SETUPCOLOURS - paints COLTAB into the colour map via BLT_SETUP_CMAP_2,
2400 REM stepping its destination by CMAPROW after each cell (Setup_Colours)
2410 PROC SETUPCOLOURS
2415 PRINT "PAINTING COLOUR MAP"
2420 DESTADDR=CMAPBASE+1:REM BLT_SETUP_CMAP_2's original destination ($60001)
2430 FOR N=0 TO 238
2440 ADDR=CM2ADR+16:BYTEVAL=COLTAB(N):EXEC PUTBYTE
2450 ADDR=CM2ADR:EXEC KICKBLIT
2460 DESTADDR=DESTADDR+CMAPROW
2470 ADDR=CM2ADR+6:BYTEVAL=DESTADDR-INT(DESTADDR/$100)*$100:EXEC PUTBYTE
2480 ADDR=CM2ADR+7:BYTEVAL=INT(DESTADDR/$100)-INT(DESTADDR/65536)*$100:EXEC PUTBYTE
2490 ADDR=CM2ADR+8:BYTEVAL=INT(DESTADDR/65536):EXEC PUTBYTE
2500 NEXT N
2510 ENDPROC
2520 REM
2530 REM CYCLEVIDCTL - Cycles through all values for VID_CTL
2540 PROC CYCLEVIDCTL
2550 FOR A=0 TO 255
2560   POKE VBASE+VIDCTL,A
2570   ? "VID_CTL: ";HEX$(A)
2580   PAUSE 40
2590 NEXT A
2600 ENDPROC
2610 REM
5000 REM XDL_Attribute (21 bytes) + XDL_Normal (12 bytes) - see xdl.asm
5010 DATA 106,14,238,0,0,2,0,2,0,0,6
5020 DATA 40,0,0,0,31,0,17,255,0,128
5030 DATA 114,8,238,0,0,2,0,2,17,255,0,128
5100 REM BLT_CLEAR (21 bytes) - see bcbs.asm
5110 DATA 0,0,0,0,0,0,255,191,7,128,240
5120 DATA 255,239,1,15,0,0,0,119,0,0
5200 REM BLT_SETUP_CMAP_1 (21 bytes) - see bcbs.asm
5210 DATA 0,0,0,0,0,0,3,0,6,40,0
5220 DATA 4,9,0,239,0,80,0,0,0,0
5300 REM BLT_SETUP_CMAP_2 (21 bytes) - see bcbs.asm
5310 DATA 0,0,0,0,0,0,1,0,6,40,0
5320 DATA 4,9,0,0,0,105,0,0,0,0
5400 REM BLT_BALL (21 bytes) - see bcbs.asm
5410 DATA 0,0,1,32,0,1,0,0,2,0,2
5420 DATA 1,31,0,31,255,0,0,0,0,1
9000 REM ---- Main ----
9010 EXEC DETECTVBXE
9020 IF FOUND=0 THEN PRINT "VBXE NOT FOUND":END
9030 IF VBASE=$D600 THEN PRINT "VBXE FOUND AT $D600"
9040 IF VBASE=$D700 THEN PRINT "VBXE FOUND AT $D700"
9050 EXEC SETUPVBXE
9060 EXEC LOADBCB
9070 EXEC CLEARVBXE
9080 EXEC LOADBCB:REM Must reload after clearing the VBXE RAM
9090 EXEC LOADXDL
9092 EXEC LOADPALETTE
9094 EXEC SETPALETTE1
9100 EXEC DRAWFUJIS
9105 EXEC SETUPDISPLAYLIST
9110 EXEC ACTIVATECOLOURMAP
9120 EXEC GENERATECOLOURMAP
9140 PRINT "XDL_ATTRIBUTE @ ";XDLADR;"  XDL_NORMAL @ ";XDLNORM
9150 PRINT "BLT_CLEAR @ ";BCBADR;"  CMAP1 @ ";CM1ADR;"  CMAP2 @ ";CM2ADR;"  BALL @ ";BALLADR
9155 PRINT "PALETTE @ ";PALADR;" (BANK 1)  PALETTE 1 LOADED"
9160 PRINT "COLOUR MAP BASE ";CMAPBASE;"  ROW STRIDE ";CMAPROW
9170 PRINT "COLOUR MAP + XCOLOR OVERLAY IS NOW ON."
9180 PRINT "POKE VBASE+VIDCTL,0 TO TURN THE OVERLAY OFF."
9190 PRINT "SET ROWNUM,COLNUM,CIDX,CPRI THEN EXEC POKECELL TO EDIT A CELL."
9200 END
9300 POKE VBASE+VIDCTL,0:REM Turn VBXE Overlays off
