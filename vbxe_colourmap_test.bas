100 REM =====================================================
110 REM  VBXE ATTRIBUTE COLOUR-MAP TEST BED - Turbo-BASIC XL
120 REM  Ports the VBXE init from init_vbxe.asm: detects VBXE,
130 REM  clears VBXE RAM, loads the XDLs (xdl.asm) and the
140 REM  colour-map BCBs (bcbs.asm) into VBXE RAM at the same
150 REM  addresses demo.asm uses, then turns on the XDL/XCOLOR
160 REM  overlay so the attribute map can be edited live from
170 REM  BASIC while running on real hardware.
180 REM
190 REM  After RUN completes, use direct mode to experiment:
200 REM    EXEC POKECELL,ROW,COL,COLOURINDEX,PRIORITYBYTE
210 REM    EXEC PUTBYTE,ADDRESS,VALUE
220 REM    EXEC GETBYTE,ADDRESS : PRINT GBRES
230 REM  ROW is 0-239, COL is 0-79. PRIORITYBYTE is normally 80
240 REM  ($50, set by PrimeColourMap). ADDRESS is any linear
250 REM  VBXE address 0-524287.
260 REM  POKE VBASE+VIDCTL,0 turns the overlay back off.
270 REM =====================================================
280 REM
290 REM ---- VBXE register offsets (add to VBASE) ----
300 VIDCTL=64:XDL0=65:XDL1=66:XDL2=67
310 BLADR0=80:BLADR1=81:BLADR2=82:BLBUSY=83
320 MACTL=94:MABSEL=95
330 REM
340 REM ---- VBXE memory-map constants (linear VBXE addresses) ----
350 XDLADR=1024:REM $0400 XDL_Attribute (XDL_Normal follows at +21=$0415)
360 XDLNORM=XDLADR+21
370 BCBADR=1280:REM $0500 BLT_CLEAR
380 CM1ADR=BCBADR+21:REM $0515 BLT_SETUP_CMAP_1
390 CM2ADR=CM1ADR+21:REM $052A BLT_SETUP_CMAP_2
400 CMAPBASE=393216:REM $60000 start of the attribute colour map
410 CMAPROW=320:REM $140 bytes per screen line (80 cells * 4 bytes)
420 WINDOW=8192:REM $2000 CPU-side address the VBXE window maps to
430 GOTO 9000
440 REM
1000 PROC DetectVBXE
1010 VBASE=54848:REM try VBXE at $D640
1020 POKE VBASE+VIDCTL,0
1030 IF PEEK(VBASE+VIDCTL)=16 THEN FOUND=1:ENDPROC
1040 VBASE=55104:REM try VBXE at $D740
1050 POKE VBASE+VIDCTL,0
1060 IF PEEK(VBASE+VIDCTL)=16 THEN FOUND=1:ENDPROC
1070 FOUND=0
1080 ENDPROC
1090 REM
1100 PROC PUTBYTE, ADDR, BYTEVAL; BANK, OFS
1110 BANK=INT(ADDR/4096)
1120 OFS=ADDR-BANK*4096
1130 POKE VBASE+MABSEL,BANK+128
1140 POKE WINDOW+OFS,BYTEVAL
1150 ENDPROC
1160 REM
1170 PROC GETBYTE, ADDR; BANK, OFS
1180 BANK=INT(ADDR/4096)
1190 OFS=ADDR-BANK*4096
1200 POKE VBASE+MABSEL,BANK+128
1210 GBRES=PEEK(WINDOW+OFS)
1220 ENDPROC
1230 REM
1240 PROC KICKBLIT, ADDR
1250 REPEAT
1260 UNTIL PEEK(VBASE+BLBUSY)=0
1270 POKE VBASE+BLADR0,ADDR-INT(ADDR/256)*256
1280 POKE VBASE+BLADR1,INT(ADDR/256)-INT(ADDR/65536)*256
1290 POKE VBASE+BLADR2,INT(ADDR/65536)
1300 POKE VBASE+BLBUSY,1
1310 REPEAT
1320 UNTIL PEEK(VBASE+BLBUSY)=0
1330 ENDPROC
1340 REM
1350 PROC LOADXDL
1360 RESTORE 5000
1370 FOR I=0 TO 32
1380 READ V
1390 EXEC PUTBYTE,XDLADR+I,V
1400 NEXT I
1410 ENDPROC
1420 REM
1430 PROC LOADBCB
1440 RESTORE 5100
1450 FOR I=0 TO 20
1460 READ V
1470 EXEC PUTBYTE,BCBADR+I,V
1480 NEXT I
1490 RESTORE 5200
1500 FOR I=0 TO 20
1510 READ V
1520 EXEC PUTBYTE,CM1ADR+I,V
1530 NEXT I
1540 RESTORE 5300
1550 FOR I=0 TO 20
1560 READ V
1570 EXEC PUTBYTE,CM2ADR+I,V
1580 NEXT I
1590 ENDPROC
1600 REM
1610 PROC CLEARVBXE
1620 EXEC KICKBLIT,BCBADR
1630 ENDPROC
1640 REM
1650 PROC PRIMECOLOURMAP
1660 EXEC KICKBLIT,CM1ADR
1670 ENDPROC
1680 REM
1690 PROC ACTIVATECOLOURMAP
1700 POKE VBASE+XDL0,XDLADR-INT(XDLADR/256)*256
1710 POKE VBASE+XDL1,INT(XDLADR/256)-INT(XDLADR/65536)*256
1720 POKE VBASE+XDL2,INT(XDLADR/65536)
1730 POKE VBASE+VIDCTL,3
1740 ENDPROC
1750 REM
1760 PROC ACTIVATENORMAL
1770 POKE VBASE+XDL0,XDLNORM-INT(XDLNORM/256)*256
1780 POKE VBASE+XDL1,INT(XDLNORM/256)-INT(XDLNORM/65536)*256
1790 POKE VBASE+XDL2,INT(XDLNORM/65536)
1800 POKE VBASE+VIDCTL,1
1810 ENDPROC
1820 REM
1830 PROC POKECELL, ROWNUM, COLNUM, CIDX, CPRI; CADR
1840 CADR=CMAPBASE+ROWNUM*CMAPROW+COLNUM*4
1850 EXEC PUTBYTE,CADR+1,CIDX
1860 EXEC PUTBYTE,CADR+3,CPRI
1870 ENDPROC
1880 REM
5000 REM XDL_Attribute (21 bytes) + XDL_Normal (12 bytes) - see xdl.asm
5010 DATA 106,14,238,0,0,2,0,2,0,0,6
5020 DATA 64,1,0,0,31,0,17,255,0,128
5030 DATA 114,8,238,0,0,2,0,2,17,255,0,128
5100 REM BLT_CLEAR (21 bytes) - see bcbs.asm
5110 DATA 0,0,0,0,0,0,255,191,7,128,240
5120 DATA 255,239,1,15,0,0,0,119,0,0
5200 REM BLT_SETUP_CMAP_1 (21 bytes) - see bcbs.asm
5210 DATA 0,0,0,0,0,0,3,0,6,64,1
5220 DATA 4,63,1,239,0,80,0,0,0,0
5300 REM BLT_SETUP_CMAP_2 (21 bytes) - see bcbs.asm
5310 DATA 0,0,0,0,0,0,1,0,6,64,1
5320 DATA 4,39,0,0,0,105,0,0,0,0
9000 REM ---- Main ----
9010 EXEC DETECTVBXE
9020 IF FOUND=0 THEN PRINT "VBXE NOT FOUND":END
9030 IF VBASE=54848 THEN PRINT "VBXE FOUND AT $D640"
9040 IF VBASE=55104 THEN PRINT "VBXE FOUND AT $D740"
9050 EXEC LOADBCB
9060 EXEC CLEARVBXE
9070 EXEC LOADXDL
9080 EXEC PRIMECOLOURMAP
9090 EXEC ACTIVATECOLOURMAP
9100 PRINT "XDL_ATTRIBUTE @ ";XDLADR;"  XDL_NORMAL @ ";XDLNORM
9110 PRINT "BLT_CLEAR @ ";BCBADR;"  CMAP1 @ ";CM1ADR;"  CMAP2 @ ";CM2ADR
9120 PRINT "COLOUR MAP BASE ";CMAPBASE;"  ROW STRIDE ";CMAPROW
9130 PRINT "COLOUR MAP + XCOLOR OVERLAY IS NOW ON."
9140 PRINT "POKE VBASE+VIDCTL,0 TO TURN THE OVERLAY OFF."
9150 PRINT "EXEC POKECELL,ROW,COL,COLOURINDEX,PRIORITYBYTE TO EDIT A CELL."
9160 END
