100 REM =====================================================
110 REM  VBXE ATTRIBUTE COLOUR-MAP TEST BED - Turbo-BASIC XL
120 REM  Ports the VBXE init from init_vbxe.asm: detects VBXE,
130 REM  clears VBXE RAM, loads the XDLs (xdl.asm) and the
140 REM  colour-map BCBs (bcbs.asm) into VBXE RAM at the same
150 REM  addresses demo.asm uses, then turns on the XDL/XCOLOR
160 REM  overlay so the attribute map can be edited live from
170 REM  BASIC while running on real hardware.
180 REM
190 REM  PROCs take no arguments (Turbo-BASIC XL PROC/EXEC does
200 REM  not support parameter lists - all variables are global
210 REM  with no scoping). Set the input variables, then EXEC.
220 REM  After RUN completes, use direct mode to experiment:
230 REM    ROWNUM=r:COLNUM=c:CIDX=i:CPRI=p:EXEC POKECELL
240 REM    ADDR=a:BYTEVAL=v:EXEC PUTBYTE
250 REM    ADDR=a:EXEC GETBYTE : PRINT GBRES
260 REM  ROW is 0-239, COL is 0-79. PRIORITYBYTE is normally $50
270 REM  (set by PrimeColourMap). ADDRESS is any linear VBXE
280 REM  address $00000-$7FFFF.
290 REM  POKE VBASE+VIDCTL,0 turns the overlay back off.
300 REM =====================================================
310 REM
320 REM ---- VBXE register offsets (add to VBASE) ----
330 VIDCTL=$40:XDL0=$41:XDL1=$42:XDL2=$43
340 BLADR0=$50:BLADR1=$51:BLADR2=$52:BLBUSY=$53
350 MACTL=$5E:MABSEL=$5F
360 REM
370 REM ---- VBXE memory-map constants (linear VBXE addresses) ----
380 XDLADR=$400:REM XDL_Attribute (XDL_Normal follows at +$15=$415)
390 XDLNORM=XDLADR+$15
400 BCBADR=$500:REM BLT_CLEAR
410 CM1ADR=BCBADR+$15:REM BLT_SETUP_CMAP_1
420 CM2ADR=CM1ADR+$15:REM BLT_SETUP_CMAP_2
430 CMAPBASE=393216:REM $60000 start of the attribute colour map (>$FFFF, must stay decimal)
440 CMAPROW=$140:REM bytes per screen line (80 cells * 4 bytes)
450 WINDOW=$6000:REM CPU-side address the VBXE window maps to
460 GOTO 9000
470 REM
1000 PROC DetectVBXE
1010 VBASE=$D600:REM try VBXE based at $D600 (VIDCTL @ $D640)
1020 POKE VBASE+VIDCTL,0:REM Use 5 when using VBXE.SYS via SDX
1030 IF PEEK(VBASE+VIDCTL)=$10 THEN FOUND=1:ENDPROC
1040 VBASE=$D700:REM try VBXE based at $D700 (VIDCTL @ $D740)
1050 POKE VBASE+VIDCTL,0:REM Use 5 when using VBXE.SYS via SDX
1060 IF PEEK(VBASE+VIDCTL)=$10 THEN FOUND=1:ENDPROC
1070 FOUND=0
1080 ENDPROC
1082 REM SETUPVBXE - points the CPU window at VBXE_WINDOW, size 4k (init_vbxe.asm clear_vbxe)
1084 PROC SETUPVBXE
1086 POKE VBASE+MACTL,INT(WINDOW/$100)+8
1088 ENDPROC
1090 REM
1100 REM PUTBYTE - in: ADDR,BYTEVAL - writes BYTEVAL to VBXE address ADDR
1110 PROC PUTBYTE
1120 BANK=INT(ADDR/$1000)
1130 OFS=ADDR-BANK*$1000
1140 POKE VBASE+MABSEL,BANK+$80:REM ? HEX$(VBASE+MABSEL),HEX$(BANK+$80)
1150 POKE WINDOW+OFS,BYTEVAL:REM ? HEX$(WINDOW+OFS),HEX$(BYTEVAL)
1160 ENDPROC
1170 REM
1180 REM GETBYTE - in: ADDR - out: GBRES - reads VBXE address ADDR
1190 PROC GETBYTE
1200 BANK=INT(ADDR/$1000)
1210 OFS=ADDR-BANK*$1000
1220 POKE VBASE+MABSEL,BANK+$80
1230 GBRES=PEEK(WINDOW+OFS)
1240 ENDPROC
1250 REM
1260 REM KICKBLIT - in: ADDR - fires the blitter on the BCB at VBXE address ADDR
1270 PROC KICKBLIT
1280 REPEAT
1290 UNTIL PEEK(VBASE+BLBUSY)=0
1300 POKE VBASE+BLADR0,ADDR-INT(ADDR/$100)*$100
1310 POKE VBASE+BLADR1,INT(ADDR/$100)-INT(ADDR/65536)*$100
1320 POKE VBASE+BLADR2,INT(ADDR/65536)
1330 POKE VBASE+BLBUSY,$01
1340 REPEAT
1350 UNTIL PEEK(VBASE+BLBUSY)=0
1360 ENDPROC
1370 REM
1380 PROC LOADXDL
1390 RESTORE 5000
1400 FOR I=0 TO $20
1410 READ V
1420 ADDR=XDLADR+I:BYTEVAL=V:EXEC PUTBYTE
1430 NEXT I
1440 ENDPROC
1450 REM
1460 PROC LOADBCB
1470 RESTORE 5100
1480 FOR I=0 TO $14
1490 READ V
1500 ADDR=BCBADR+I:BYTEVAL=V:EXEC PUTBYTE
1510 NEXT I
1520 RESTORE 5200
1530 FOR I=0 TO $14
1540 READ V
1550 ADDR=CM1ADR+I:BYTEVAL=V:EXEC PUTBYTE
1560 NEXT I
1570 RESTORE 5300
1580 FOR I=0 TO $14
1590 READ V
1600 ADDR=CM2ADR+I:BYTEVAL=V:EXEC PUTBYTE
1610 NEXT I
1620 ENDPROC
1630 REM
1640 PROC CLEARVBXE
1650 ADDR=BCBADR:EXEC KICKBLIT
1660 ENDPROC
1670 REM
1680 PROC PRIMECOLOURMAP
1690 ADDR=CM1ADR:EXEC KICKBLIT
1700 ENDPROC
1710 REM
1720 PROC ACTIVATECOLOURMAP
1730 POKE VBASE+XDL0,XDLADR-INT(XDLADR/$100)*$100
1740 POKE VBASE+XDL1,INT(XDLADR/$100)-INT(XDLADR/65536)*$100
1750 POKE VBASE+XDL2,INT(XDLADR/65536)
1760 POKE VBASE+VIDCTL,$03
1770 ENDPROC
1780 REM
1790 PROC ACTIVATENORMAL
1800 POKE VBASE+XDL0,XDLNORM-INT(XDLNORM/$100)*$100
1810 POKE VBASE+XDL1,INT(XDLNORM/$100)-INT(XDLNORM/65536)*$100
1820 POKE VBASE+XDL2,INT(XDLNORM/65536)
1830 POKE VBASE+VIDCTL,$01
1840 ENDPROC
1850 REM
1860 REM POKECELL - in: ROWNUM,COLNUM,CIDX,CPRI - writes one colour-map cell
1870 PROC POKECELL
1880 CADR=CMAPBASE+ROWNUM*CMAPROW+COLNUM*$04
1890 ADDR=CADR+1:BYTEVAL=CIDX:EXEC PUTBYTE
1900 ADDR=CADR+3:BYTEVAL=CPRI:EXEC PUTBYTE
1910 ENDPROC
1920 REM
2000 REM
2010 PROC DRAWFUJIS
2020 GRAPHICS 8
2030 POKE $02C5,$08:REM lda #$08:sta COLOR1
2040 POKE $02C6,$00:REM lda #$00:sta COLOR2
2050 SAVMSC=DPEEK($58):SIZE=$0208
2060 FOR ROW=0 TO 11
2070   ADRS=SAVMSC+(ROW*SIZE)
2080   CLOSE :OPEN #1,4,0,"D:FUJIMONO.RAW"
2090   BGET #1,ADRS,SIZE
2100 NEXT ROW
2120 ENDPROC
2130 REM
5000 REM XDL_Attribute (21 bytes) + XDL_Normal (12 bytes) - see xdl.asm
5010 DATA 106,14,238,0,0,2,0,2,0,0,6
5020 DATA 64,1,0,0,31,0,17,255,0,128
5030 DATA 114,8,238,0,0,2,0,2,17,255,0,128
5100 REM BLT_CLEAR (21 bytes) - see bcbs.asm
5110 DATA 0,0,0,0,0,0,255,191,7,128,240
5120 DATA 255,239,1,15,0,0,0,119,0,0
5200 REM BLT_SETUP_CMAP_1 (21 bytes) - see bcbs.asm
5210 DATA 0,0,0,0,0,0,3,0,6,64,1
5220 DATA 4,63,1,239,0,80,0,0,0,0
5300 REM BLT_SETUP_CMAP_2 (21 bytes) - see bcbs.asm
5310 DATA 0,0,0,0,0,0,1,0,6,64,1
5320 DATA 4,39,0,0,0,105,0,0,0,0
9000 REM ---- Main ----
9010 EXEC DETECTVBXE
9020 IF FOUND=0 THEN PRINT "VBXE NOT FOUND":END
9030 IF VBASE=$D600 THEN PRINT "VBXE FOUND AT $D600"
9040 IF VBASE=$D700 THEN PRINT "VBXE FOUND AT $D700"
9050 EXEC SETUPVBXE
9060 EXEC LOADBCB
9070 EXEC CLEARVBXE
9080 EXEC LOADXDL
9090 EXEC DRAWFUJIS
9100 EXEC PRIMECOLOURMAP
9110 EXEC ACTIVATECOLOURMAP
9120 PRINT "XDL_ATTRIBUTE @ ";XDLADR;"  XDL_NORMAL @ ";XDLNORM
9130 PRINT "BLT_CLEAR @ ";BCBADR;"  CMAP1 @ ";CM1ADR;"  CMAP2 @ ";CM2ADR
9140 PRINT "COLOUR MAP BASE ";CMAPBASE;"  ROW STRIDE ";CMAPROW
9150 PRINT "COLOUR MAP + XCOLOR OVERLAY IS NOW ON."
9160 PRINT "POKE VBASE+VIDCTL,0 TO TURN THE OVERLAY OFF."
9170 PRINT "SET ROWNUM,COLNUM,CIDX,CPRI THEN EXEC POKECELL TO EDIT A CELL."
9180 END
9200 POKE VBASE+VODCTL,0:REM Turn VBXE Overlays off
