    79 2559 00				dta $00								; Source step x
    80 255A 01 00 06			dta $01,$00,$06						; Destination address ($60001)
    81 255D 28 00			dta $28,$00							; Destination step y ($28 bytes/line)
    82 255F 04				dta $04								; Destination step x
    83 2560 09 00			dta $09,$00							; Width (9 = 10 cells/line, count-1)
    84 2562 00				dta $00								; Height ($01)
    85 2563 00				dta $00								; And mask
    86 2564 69				dta $69								; Xor mask
    87 2565 00				dta $00								; Collision and mask
    88 2566 00				dta $00								; Zoom
    89 2567 00				dta $00								; Pattern feature
    90 2568 00				dta $00								; Control
