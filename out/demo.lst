   114
   115 				vblda	.macro
   116 				.ifdef	__VBXE_AUTO__
   117 					lda	VBXEBase+1
   118 					sta	vblda_adr
   119 					lda.w	:1
   120 				vblda_adr	equ *-1
   121 				.else
   122 					lda	:1
   123 				.endif
   124 				.endm
