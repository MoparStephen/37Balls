   726 				;-----------------------------------------------------------------------------
   727 				; Calculate_200
   728 				;   Reg1 = X_Pos_L	Object Horizontal Position (Col)
   729 				;   Reg2 = X_Pos_H	Object Horizontal Position (Col)
   730 				;   Reg3 = Y_Pos	Object Vertical Position   (Row)
   731 				;   Reg4 = Adr0	   VBXE Blitter Address
   732 				;   Reg5 = Adr1	   VBXE Blitter Address
   733 				;   Reg6 = Adr2	   VBXE Blitter Address
   734 				;   Reg7 = XDL destination high byte (either 0 or 2)
   735 				;-----------------------------------------------------------------------------
   736 3614			Calculate_200
   737 				; Because we are double buffering, we need to write to the backbuffer
   738 				; So load the buffer address from the XDL but use the other one
   739 3614 AD 5F D6			lda VBXE_MA_BSEL
   740 3617 48				pha									; Store it
   741
   742 3618 A9 80			lda	#$80							; Bank $00 with global enable (XDL lives in bank $00)
   743 361A 8D 5F D6			sta	VBXE_MA_BSEL
   744
   745 361D AD 05 24			lda	VBXE_WINDOW + $405				; XDL Adr2 (byte 5 of XDL at VBXE_WINDOW+$400)
   746 3620 49 06			eor	#$06							; Flip between $02 ($020000) and $04 ($040000)
   747 3622 85 86			sta	Reg7							; Reg7 = backbuffer Adr2
   748
   749 				; Calculate the start of VRAM (Reg4, Reg5, Reg6) for the given Y-Pos
   750 3624 A9 00			lda #$00
   751 3626 85 83			sta Reg4							; Reset to initial value
   752 3628 85 85			sta Reg6							; Reset to initial value
   753 362A A5 82			lda Reg3							; Y_Pos
   754 362C 10 04			bpl Skip_Reg6						; If A <= $7F Reg6 will be 0
   755 362E A0 01			ldy #$01							; Else
   756 3630 84 85			sty Reg6							; Reg6 = 1
   757 3632			Skip_Reg6
   758 3632 0A				asl									; Multiply by 2
   759 3633 85 84			sta Reg5
   760
   761 				; Now move into that line in VRAM based on the X-Position
   762 3635 18				clc									; Prepare to add
   763 3636 A5 80			lda Reg1							; X_Pos_L
   764 3638 65 83			adc Reg4							; Add Adr0
   765 363A 85 83			sta Reg4							; Store it
   766 363C A5 81			lda Reg2							; X_Pos_H
   767 363E 65 84			adc Reg5							; Add Adr1
   768 3640 85 84			sta Reg5							; Store it
   769 3642 A9 00			lda #$00
   770 3644 65 85			adc Reg6							; Account for overflow
   771 3646 85 85			sta Reg6							; Store Adr2
   772
   773 				; Set Adr 2 depending on which buffer we are writing to
   774 3648 18				clc									; Prepare to add
   775 3649 A5 86			lda Reg7
   776 364B 65 85			adc Reg6							; Carry flag weill NEVER be set, as value will only ever be 0-1 or 2-3
   777 364D 85 85			sta Reg6
   778 364F			Calculate_200_End						; This takes on average $37(55) cycles, code is $22(34) bytes TODO: Calculate new cycle time based on code to handle double buffering
   779 364F 68				pla
   780 3650 8D 5F D6			sta VBXE_MA_BSEL					; Restore to initial value
   781
   782 3653 60				rts
   783
   784 				;-----------------------------------------------------------------------------
   785 				; Setup_DisplayList - Points ANTIC to a Display List that will be in VBXE RAM
   786 				;-----------------------------------------------------------------------------
   787 3654			Setup_DisplayList
   788 3654 AD 2F 02			lda SDMCTL
   789 3657 48				pha									; Save it
   790
   791 3658 A9 00			lda #$00							; Turn off ANTIC DMA
   792 365A 8D 2F 02			sta SDMCTL							; to safely set SDLSTL
   793
   794 365D A9 00			lda <Display_List
   795 365F 8D 30 02			sta SDLSTL
   796 3662 A9 59			lda >Display_List
   797 3664 8D 31 02			sta SDLSTH
   798
   799 3667 68				pla									; Restore it
   800 3668 8D 2F 02			sta SDMCTL
   801
   802 366B 60				rts									; Go Home
   803
   804 				;-----------------------------------------------------------------------------
   805 				; Generate_Colour_Map
   806 				; This will generate the 9600 byte colour map used by the VBXE
   807 				;-----------------------------------------------------------------------------
   808 366C			Generate_Colour_Map
   809 366C A9 00			lda #$00
   810 366E 85 88			sta Ptr_Lo
   811 3670 A9 06			lda #$06
   812 3672 85 89			sta Ptr_Hi							; Initialize destination pointer to $0600
   813
   814 3674 A9 01			lda #$01
   815 3676 85 80			sta Reg1							; Running colour accumulator
   816
   817 3678 A2 00			ldx #$00							; Object counter (0-15)
   818 367A			obj_loop
   819 367A A0 00			ldy #$00							; Row counter (0-14)
   820 367C			row_loop
   821 367C A9 00			lda #$00							; Default: blank row
   822 367E C0 00			cpy #$00
   823 3680 F0 08			beq store_colour
   824 3682 C0 0E			cpy #$0E
   825 3684 F0 04			beq store_colour
   826 3686 A5 80			lda Reg1							; Non-blank row: use accumulator
   827 3688 E6 80			inc Reg1
   828 368A			store_colour
   829 368A 91 88			sta (Ptr_Lo),Y
   830
   831 368C C8				iny
   832 368D C0 0F			cpy #$0F							; 15 rows per object
   833 368F D0 EB			bne row_loop
   834
   835 				; Advance pointer by 15 to next object's base
   836 3691 A5 88			lda Ptr_Lo
   837 3693 18				clc
   838 3694 69 0F			adc #$0F
   839 3696 85 88			sta Ptr_Lo
   840 3698 90 02			bcc no_carry
   841 369A E6 89			inc Ptr_Hi
   842 369C			no_carry
   843 369C E8				inx
   844 369D E0 10			cpx #$10							; 16 objects
   845 369F D0 D9			bne obj_loop
   846
   847 36A1 20 D8 35			jsr Setup_Cmap1						; Setup the Palette & Priority bits
   848 36A4 20 A8 36			jsr Setup_Colours
   849
   850 36A7 60				rts
   851
   852 				;-----------------------------------------------------------------------------
   853 				; Setup_Colours
   854 				; Uses the temp table at $600 to setup the Attribute COlour Map
   855 				;-----------------------------------------------------------------------------
   856 36A8			Setup_Colours
   857 				; Turn on VBXE window so we can modify the BCB
   858 36A8 A9 80			lda	#$80							; Copy some data into VBXE address space (XDL, Blitter control blocks (BCB))
   859 36AA 8D 5F D6			sta	VBXE_MA_BSEL
   860
   861 36AD A2 00			ldx #$00							; Prepare to loop
   862 36AF			Setup_Colours_L1
   863 36AF BD 00 06			lda $600,x							; Get the colour
   864 36B2 8D 64 25			sta	VBXE_WINDOW+$554+$10			; BLT_SETUP_CMAP_2 starts at $0554 in VBXE bank 0, XOR Mask is offset $10
   865
   866 36B5 20 F6 35			jsr Setup_Cmap2						; Setup a row of colours
   867
   868 				; Now we must do a 24-bit addition to get the next Destination Address (offset 6,7,8)
   869 36B8 18				clc
   870 36B9 AD 5A 25			lda VBXE_WINDOW+$554+$06			; Dest Addr 2
   871 36BC 69 40			adc #$40
   872 36BE 8D 5A 25			sta VBXE_WINDOW+$554+$06			; Dest Addr 2
   873
   874 36C1 AD 5B 25			lda VBXE_WINDOW+$554+$07			; Dest Addr 1
   875 36C4 69 01			adc #$01
   876 36C6 8D 5B 25			sta VBXE_WINDOW+$554+$07			; Dest Addr 1
   877
   878 36C9 AD 5C 25			lda VBXE_WINDOW+$554+$08			; Dest Addr 0
   879 36CC 69 00			adc #$00
   880 36CE 8D 5C 25			sta VBXE_WINDOW+$554+$08			; Dest Addr 1
   881
   882 36D1 E8				inx
   883 36D2 E0 EF			cpx #$EF
   884 36D4 D0 D9			bne Setup_Colours_L1
   885
   886 36D6 60				rts
   887 				;-----------------------------------------------------------------------------
   888 				; Subroutines END
   889 				;-----------------------------------------------------------------------------
   890
   891 				;-----------------------------------------------------------------------------
   892 				; Data Tables go here
   893 				;-----------------------------------------------------------------------------
   894 				; 37 velocity patterns - one per sprite, every (int,frac) pair unique
   895 				; X: integer $00-$03 cycles with period 4; frac rotates +$40 each int group
   896 				; Y: integer offset by 1 ($01-$03,$00); frac rotates +$20 relative to X â†’ no correlation
   897 36D7			Init_Delta_X
   898 36D7 01 01 02 03 00 01 + 	dta	$01,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03
   899 36E7 00 01 02 03 00 01 + 	dta	$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03
   900 36F7 00 01 02 03 00		dta	$00,$01,$02,$03,$00
   901 36FC			Init_Delta_X_Frac
   902 36FC 00 40 80 C0 10 50 + 	dta	$00,$40,$80,$C0,$10,$50,$90,$D0,$20,$60,$A0,$E0,$30,$70,$B0,$F0
   903 370C 40 80 C0 00 50 90 + 	dta	$40,$80,$C0,$00,$50,$90,$D0,$10,$60,$A0,$E0,$20,$70,$B0,$F0,$30
   904 371C 80 C0 00 40 90		dta	$80,$C0,$00,$40,$90
   905 3721			Init_Delta_Y
   906 3721 06 02 03 00 01 02 + 	dta	$06,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$01,$01,$02,$03,$00
   907 3731 01 02 03 00 01 02 + 	dta	$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00
   908 3741 01 02 03 00 01		dta	$01,$02,$03,$00,$01
   909 3746			Init_Delta_Y_Frac
   910 3746 00 60 A0 E0 30 70 + 	dta	$00,$60,$A0,$E0,$30,$70,$B0,$F0,$40,$80,$C0,$00,$50,$90,$D0,$10
   911 3756 60 A0 E0 20 70 B0 + 	dta	$60,$A0,$E0,$20,$70,$B0,$F0,$30,$80,$C0,$00,$40,$90,$D0,$10,$50
   912 3766 A0 E0 20 60 B0		dta	$A0,$E0,$20,$60,$B0
   913
   914 				; Standard Atari ROM font for 3 and 7, laid out by hand, then auto-generated tables based on my grid
   915 376B			Init_Pos_X_Lo
   916 376B 12 24 36 48 5A 6C + 	dta	$12,$24,$36,$48,$5A,$6C,$A2,$B4,$C6,$D8,$EA,$FC,$48,$5A,$A2,$EA		; Objs $00-$0F
   917 377B FC 36 48 D8 EA 48 + 	dta	$FC,$36,$48,$D8,$EA,$48,$5A,$C6,$D8,$12,$24,$5A,$6C,$B4,$C6,$24		; Objs $10-$1F
   918 378B 36 48 5A B4 C6		dta	$36,$48,$5A,$B4,$C6													; Objs $20-$24
   919 3790			Init_Pos_Y
