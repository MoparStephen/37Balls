   652 				;-----------------------------------------------------------------------------
   653 				; Wait For VSync (locks to the refresh rate, PAL=50Hz, NTSC=60Hz)  Thanks tebe
   654 				;-----------------------------------------------------------------------------
   655 35A5			Wait_For_Sync							; Hold until VCOUNT == 0
   656 35A5 2C 0B D4			bit VCOUNT
   657 35A8 30 FB			bmi *-3
   658 35AA 2C 0B D4			bit	VCOUNT
   659 35AD 10 FB			bpl *-3
   660 				; If present, the next 3 lines will allow a 'jump to exit' on a specific key press
   661 35AF AD FC 02			lda CH
   662 35B2 C9 2F			cmp #$2F							; Press Q to quit
   663 35B4 F0 01			beq Exit_Long
   664 35B6 60				rts									; Else return to caller
   665
   666 35B7			Exit_Long
   667 35B7 4C D2 31			jmp Cleanup_Exit					; Fix for branch out of range
   668
   669 				;-----------------------------------------------------------------------------
