    22 				;-----------------------------------------------------------------------------
    23 				; Structure Declarations
    24 				;-----------------------------------------------------------------------------
    25 				.struct Sprite
    26 = 0000				X_Pos_Frac .byte					; Horizontal position (Fractional) sprite1
    27 = 0001				X_Pos_Lo .byte						; Horizontal position sprite1
    28 = 0002				X_Pos_Hi .byte						; Horizontal position sprite1 (Valid Values 0-319)
    29 = 0003				Y_Pos_Frac .byte					; Vertical position (Fractional) sprite1
    30 = 0004				Y_Pos .byte							; Vertical position sprite1 (valid values 0-239)
    31 = 0005				Delta_X_Sign .byte					; X-Delta Sign (toggles betwen $00:Right, $FF:Left)
    32 = 0006				Delta_X_Frac .byte					; Fractional X-Delta
    33 = 0007				Delta_X .byte						; X-Delta (Valid Values) (+ = move right, - = move left)
    34 = 0008				Delta_Y_Sign .byte					; Y-Delta Sign (toggles betwen $00:Down, $FF:Up)
    35 = 0009				Delta_Y_Frac .byte					; Fractional Y-Delta
    36 = 000A				Delta_Y .byte						; Y-Delta (Valid Values) (+ = move down, - = move up)
    37 				.ends
    38
    39 				;-----------------------------------------------------------------------------
    40 				; Variables go here
    41 				;-----------------------------------------------------------------------------
    42 				; Page 0 user data ($80 to $FF with some reserved for OS)
