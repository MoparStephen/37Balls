   624 3577			Flip_Screen
   625 3577 A9 80			lda	#$80
   626 3579 8D 5F D6			sta	VBXE_MA_BSEL
   627 357C AD 05 24			lda	VBXE_WINDOW+$405
   628 357F 8D 08 25			sta	VBXE_WINDOW+$500+BLT_BALL-BLT_BALL+8
   629 3582 8D 1D 25			sta	VBXE_WINDOW+$500+BLT_BAKGRND-BLT_BALL+8
   630 3585 49 06			eor	#6								; Flip screen between $20000 and $40000
