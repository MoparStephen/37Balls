   726 				;-----------------------------------------------------------------------------
   727 				; Calculate_200
   728 				;   Reg1 = X_Pos_L	Object Horizontal Position (Col)
   729 				;   Reg2 = X_Pos_H	Object Horizontal Position (Col)
   730 				;   Reg3 = Y_Pos	Object Vertical Position   (Row)
   731 				;   Reg4 = Adr0	   VBXE Blitter Address
   732 				;   Reg5 = Adr1	   VBXE Blitter Address
   733 				;   Reg6 = Adr2	   VBXE Blitter Address
   734 				;   Reg7 = XDL destination high byte (either 0 or 2)
   735 				;-----------------------------------------------------------------------------
   736 36E5			Calculate_200
   737 				; Because we are double buffering, we need to write to the backbuffer
   738 				; So load the buffer address from the XDL but use the other one
   739 36E5				vblda VBXE_MA_BSEL
Macro: VBLDA [Source: vbxe_min.asm]
     2 36E5 A5 92			lda VBXEBase+1
     3 36E7 8D EC 36			sta vblda_adr
     4 36EA AD 5F D6			lda.w VBXE_MA_BSEL
     5 = 36EC			vblda_adr	equ *-1
Source: demo.asm
   740 36ED 48				pha									; Store it
   741
   742 36EE A9 80			lda #$80							; Bank $00 with global enable (XDL lives in bank $00)
   743 36F0				vbsta VBXE_MA_BSEL
Macro: VBSTA [Source: vbxe_min.asm]
     2 36F0 48				pha
     3 36F1 A5 92			lda VBXEBase+1
     4 36F3 8D F9 36			sta vbsta_adr
     5 36F6 68				pla
     6 36F7 8D 5F D6			sta.w VBXE_MA_BSEL
     7 = 36F9			vbsta_adr	equ *-1
Source: demo.asm
   744
   745 36FA AD 05 24			lda VBXE_WINDOW + $405				; XDL Adr2 (byte 5 of XDL at VBXE_WINDOW+$400)
   746 36FD 49 06			eor #$06							; Flip between $02 ($020000) and $04 ($040000)
   747 36FF 85 86			sta Reg7							; Reg7 = backbuffer Adr2
   748
   749 				; Calculate the start of VRAM (Reg4, Reg5, Reg6) for the given Y-Pos
   750 3701 A9 00			lda #$00
   751 3703 85 83			sta Reg4							; Reset to initial value
   752 3705 85 85			sta Reg6							; Reset to initial value
   753 3707 A5 82			lda Reg3							; Y_Pos
   754 3709 10 04			bpl Skip_Reg6						; If A <= $7F Reg6 will be 0
   755 370B A0 01			ldy #$01							; Else
   756 370D 84 85			sty Reg6							; Reg6 = 1
   757 370F			Skip_Reg6
   758 370F 0A				asl									; Multiply by 2
   759 3710 85 84			sta Reg5
   760
   761 				; Now move into that line in VRAM based on the X-Position
   762 3712 18				clc									; Prepare to add
   763 3713 A5 80			lda Reg1							; X_Pos_L
   764 3715 65 83			adc Reg4							; Add Adr0
   765 3717 85 83			sta Reg4							; Store it
   766 3719 A5 81			lda Reg2							; X_Pos_H
   767 371B 65 84			adc Reg5							; Add Adr1
   768 371D 85 84			sta Reg5							; Store it
   769 371F A9 00			lda #$00
   770 3721 65 85			adc Reg6							; Account for overflow
   771 3723 85 85			sta Reg6							; Store Adr2
   772
   773 				; Set Adr 2 depending on which buffer we are writing to
   774 3725 18				clc									; Prepare to add
   775 3726 A5 86			lda Reg7
   776 3728 65 85			adc Reg6							; Carry flag weill NEVER be set, as value will only ever be 0-1 or 2-3
   777 372A 85 85			sta Reg6
   778 372C			Calculate_200_End						; This takes on average $37(55) cycles, code is $22(34) bytes TODO: Calculate new cycle time based on code to handle double buffering
   779 372C 68				pla
   780 372D				vbsta VBXE_MA_BSEL					; Restore to initial value
Macro: VBSTA [Source: vbxe_min.asm]
