   395
   396 334D			blit_clear
   397 					; clear 496kB (leave bottom 16kB for the SVBXE.SYS driver)
   398 					; 496x16 zoom 8x8 clear blit (this takes 2 frames)
   399
   400 					;	dta e($00000)	; Source address
   401 					;	dta a($0000)	; Source step y
   402 					;	dta 0			; Source step x
   403 					;	dta e($7BFFF)	; Destination address
   404 					;	dta a(-$0F80)	; Destination step y (backwards 3968 bytes) - NOTE: this equals 496 * zoom factor of 8
   405 					;	dta -1			; Destination step x (backwards	1 byte)
   406 					;	dta a($01EF)	; Width-1  (495)	496 * 8 bytes wide
   407 					;	dta $0F			; Height-1 (15)		 16 * 8 bytes high
   408 					;	dta $00			; And mask (And mask equal to 0 so clear)
   409 					;	dta $00			; Xor mask (will be filled with xor mask)
