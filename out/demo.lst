   345 3300			.proc clear_vbxe
   346 				; Print Clearing_Message - line 3 (y = $79)
   347 3300-3382> A0 79			ldy #$79
   348 3302 A2 00			ldx #$00
   349 3304			Print_Clearing_Message_L1
   350 3304 BD 62 33			lda Clearing_Message,x
