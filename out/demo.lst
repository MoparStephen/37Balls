     1 				;basic CIO commands (ICCOM)
     2 = 0003			CIO_open		equ 3					;OPEN command for IOCB channell
     3 = 0005			CIO_gettext		equ 5					;READ of text line
     4 = 0007			CIO_getdata		equ 7					;READ of binary data
     5 = 0009			CIO_puttext		equ 9					;WRITE of text line
     6 = 000B			CIO_putdata		equ 11					;WRITE of binary data
     7 = 000C			CIO_close    	equ 12					;CLOSE of IOCB channel
     8 = 000D			CIO_getstatus	equ 13					;READ of device status
     9
    10 				;some dos specific XIO commands (ICCOM)
    11 = 0029			XIO_changedir	equ 41					;Change working directory (MyDOS)
    12
    13 				;mode of operation (ICAX1) for OPEN
    14 = 0004			CIO_read     	equ 4					;open to read
    15 = 0008			CIO_write     	equ 8					;open to write
    16 = 0006			CIO_dir       	equ 6					;get directory
    17
    18 				;--------------------------------------------------------
    19 				;		Zero page variables for FileIO;
    20 				;--------------------------------------------------------
    21 3000			.zpvar	BankIndex	.word
    22 3000			.zpvar	AR_Temp		.byte
    23 3000			.zpvar	XR_Temp		.byte
    24 3000			.zpvar	YR_Temp		.byte
    25 				;--------------------------------------------------------
    26 				;		Other variables for FileIO;
    27 				;--------------------------------------------------------
    28 3000			.var	FileNamePtr	.word
    29 3000			.var	FileNameLng .byte
    30 3000			.var	TextPtr		.word
    31 3000			.var	LoadStatus	.byte				; $0 = failure, $1 = Success
    32 3000-3273> FF		Console_IOCB		.byte 0xFF
    33 3001 20 3A 9B 00		Temporary_Handler	.byte ' :',0x9B,0x00
    34 3005 53 32 3A 9B 00	VBXE_Handler		.byte 'S2:',0x9B,0x00
    35
    36 				;--------------------------------------------------------
    37 				;		Common calls for FileIO
    38 				;--------------------------------------------------------
    39
    40 				;--------------------------------------------------------
    41 				; Get_HATABS_Entry - retrives handler ID from HATABS table
    42 				; takes:
    43 				; A - HATABS offset from ICHID
    44 				; returns:
    45 				; A - letter identificator of the handler
    46 300A			Get_HATABS_Entry
    47 300A 86 8F			stx XR_Temp
    48 300C AA				tax
    49 300D BD 1A 03			lda HATABS,x
    50 3010 A6 8F			ldx XR_Temp
    51 3012 60				rts
    52 					
    53 				;--------------------------------------------------------
    54 				;Find_Matching_IOCB - search for first matching IOCB
    55 				; takes:
    56 				; A - letter identificator of the handler to look for
    57 				; returns:
    58 				; X - relative offset to first free IOCB (IOCB number *16)
    59 				; Y - error code (126 - nonexistent device) if it fails
    60
    61 3013			Find_Matching_IOCB
    62 3013 85 8E			sta AR_Temp
    63 3015 A2 00			ldx #0x00
    64 3017 A0 01			ldy #0x01
    65 3019			Find_Matching_IOCB_l1
    66 3019 BD 40 03			lda ICHID,x
    67 301C 20 0A 30			jsr Get_HATABS_Entry
    68 301F C5 8E			cmp AR_Temp							; Compare device ID with the one searched
    69 3021 F0 09			beq Find_Matching_IOCB_Found
    70 3023 8A				txa
    71 3024 18 69 10			add #0x10							; Add IOCB structure length to x pointer, and try next channel
    72 3027 AA				tax
    73 3028 10 EF			bpl Find_Matching_IOCB_l1
    74 302A A0 82			ldy #-126							; If fails, change error code to "NONEXISTENT DEVICE"	
    75 302C			Find_Matching_IOCB_Found
    76 302C 60				rts
    77
    78 				;--------------------------------------------------------
    79 				;Find_First_IOCB - search for first free IOCB
    80 				; returns:
    81 				; X - relative offset to first free IOCB (IOCB number *16)
    82 				; Y - error code (95 - too many channels open) if it fails
    83 				; 
    84 				; This piece of code comes from Polish Atariki page
    85 				; there are no references for its orgins
    86
    87 302D			Find_First_IOCB
    88 302D A2 00			ldx #0x00							; Start with channel #0
    89 302F A0 01			ldy #0x01							; Set the error code to #1 - success
    90 3031			Find_First_IOCB_l1
    91 3031 BD 40 03			lda ICHID,x							; Get the device ID
    92 3034 C9 FF			cmp #0xff							; If equals to 0xff - channel is not opened
    93 3036 F0 09			beq Find_First_IOCB_found
    94 3038 8A				txa
    95 3039 18 69 10			add #0x10							; Add IOCB structure length to x pointer, and try next channel
    96 303C AA				tax
    97 303D 10 F2			bpl Find_First_IOCB_l1
    98 303F A0 A1			ldy #-95							;if fails, change error code to "TOO MANY CHANNELS OPEN"	
    99 3041			Find_First_IOCB_found
   100 3041 60				rts
   101
   102 				;--------------------------------------------------------
   103 				; PutLine - puts line of text pointed by TextPtr
   104 				; line should end with ENTER (0x9b)
   105 3042			PutLine
   106 				;	brk
   107 3042 AE 00 30			ldx Console_IOCB
   108 3045 E0 FF			cpx #255
   109 3047 D0 10			bne PutLine_IOCB_Open
   110 3049 A9 45			lda #'E'
   111 304B 20 13 30			jsr Find_Matching_IOCB
   112 304E C0 01			cpy #1
   113 3050 F0 07			beq PutLine_IOCB_Found
   114 3052 A9 45			lda #'E'							; Open through console handler
   115 3054 A0 00			ldy #0								; Mode 0 - standard text console
   116 3056 20 73 30			jsr SetGraphicsMode
   117 3059			PutLine_IOCB_Open
   118 3059			PutLine_IOCB_Found
   119 3059 A9 09			lda #CIO_puttext
   120 305B 9D 42 03			sta iccmd,x
   121 305E A9 FF			lda #255
   122 3060 9D 48 03			sta ICBLL,x
   123 3063 AD 36 31			lda TextPtr
   124 3066 9D 44 03			sta ICBAL,x
   125 3069 AD 37 31			lda TextPtr+1
   126 306C 9D 45 03			sta ICBAL+1,x
   127 306F 20 56 E4			jsr ciov
   128 3072			PutLine_Error
   129 3072 60				rts
   130 					
   131 				;--------------------------------------------------------
   132 				; Set_Graphics_Mode - sets graphics mode
   133 				; takes:
   134 				; A - device handler (E, S, or V (S2))
   135 				; X - IOCB offset (IOCB channel number multiplied by 16)
   136 				; Y - mode to set
   137 				; returns:
   138 				; Y - error code (95 - too many channels open) if it fails
   139
   140 3073			SetGraphicsMode
   141 3073 20 2D 30			jsr Find_First_IOCB					; Find first free IOCB
   142 3076 C0 01			cpy #1
   143 3078 D0 22			bne SetGraphicsMode_Error			; No more free IOCB
   144 307A C9 56			cmp #'V'
   145 307C F0 1F			beq SetGraphicsMode_VBXE			; VBXE device handler is S2:, so we need special case for it :(
   146 307E 8D 01 30			sta Temporary_Handler
   147 3081 A9 01			lda #<Temporary_Handler
   148 3083 9D 44 03			sta ICBAL,x
   149 3086 A9 30			lda #>Temporary_Handler
   150 3088 9D 45 03			sta ICBAL+1,x
   151 308B			SetGraphicsMode_Common
   152 308B 98				tya
   153 308C 9D 4B 03			sta ICAX2,x							; Mode to obtain
   154 308F A9 03			lda #CIO_open	
   155 3091 9D 42 03			sta iccmd,x
   156 3094 A9 0C			lda #CIO_read|CIO_write				; For both READ and WRITE operations
   157 3096 9D 4A 03			sta ICAX1,x
   158 3099 20 56 E4			jsr ciov
   159 309C			SetGraphicsMode_Error
   160 309C 60				rts
   161 309D			SetGraphicsMode_VBXE
   162 309D A9 05			lda #<VBXE_Handler
   163 309F 9D 44 03			sta ICBAL,x
   164 30A2 A9 30			lda #>VBXE_Handler
   165 30A4 9D 45 03			sta ICBAL+1,x
   166 30A7 4C 8B 30			jmp SetGraphicsMode_Common
