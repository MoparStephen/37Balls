    32
    33 				; Clear 496kB (leave bottom 16kB for the SVBXE.SYS driver)
    34 				; 496x16 zoom 8x8 clear blit (this takes 2 frames)
    35 252A			BLT_CLEAR
    36 252A 00 00 00			dta $00,$00,$00						; Source address
    37 252D 00 00			dta $00,$00							; Source step y
    38 252F 00				dta $00								; Source step x
    39 2530 FF BF 07			dta $FF,$BF,$07						; Destination address
    40 2533 80 F0			dta a(-$0F80)						; Destination step y (backwards 3968 bytes) - NOTE: this equals 496 * zoom factor of 8
    41 2535 FF				dta -$01							; Destination step x (backwards	1 byte)
    42 2536 EF 01			dta $EF,$01							; Width-1  (495)	496 * 8 bytes wide
    43 2538 0F				dta $0F								; Height-1 (15)		 16 * 8 bytes high
    44 2539 00				dta $00								; And mask (And mask equal to 0 so clear)
    45 253A 00				dta $00								; Xor mask (will be filled with xor mask)
    46 253B 00				dta $00								; Collision and mask
    47 253C 77				dta $77								; Zoom (BLT_ZOOMY = 7, BLT_ZOOMX = 7 so 8Y*8X)
    48 253D 00				dta $00								; Pattern feature
    49 253E 00				dta $00								; Control (Mode 0 with NEXT bit Cleared)
    50
    51 				; Fill the ColourMap area ($60000-$62580, 9600 bytes) with $50 every 4 bytes
    52 				; XDLC_MAPPAR Byte 4
    53 				; This sets up the Palette & Priority bytes for the entire Colour Map
    54 				; 10 cells/line (32-pixel cells) x 4 bytes/cell = $28 bytes/line, 240 lines
    55 253F			BLT_SETUP_CMAP_1
    56 253F 00 00 00			dta $00,$00,$00						; Source address
    57 2542 00 00			dta $00,$00							; Source step y
    58 2544 00				dta $00								; Source step x
    59 2545 03 00 06			dta $03,$00,$06						; Destination address ($60003)
    60 2548 28 00			dta $28,$00							; Destination step y ($28 bytes/line)
    61 254A 04				dta $04								; Destination step x
    62 254B 09 00			dta $09,$00							; Width (9 = 10 cells/line, count-1)
    63 254D EF				dta $EF								; Height ($F0)
    64 254E 00				dta $00								; And mask
    65 254F 50				dta $50								; Xor mask ($50 = PF & OVL Palette 1)
    66 2550 00				dta $00								; Collision and mask
    67 2551 00				dta $00								; Zoom
    68 2552 00				dta $00								; Pattern feature
    69 2553 00				dta $00								; Control
    70
    71 				; Fill the ColourMap area with a single line ($28 bytes) of
    72 				; Local substitute of the COLPF1 register (GTIA)
    73 				; This BCB gets modified before each call
    74 				; Starting address increments by $28 each time
    75 				; Xor mask pulls values from the temp table at $0600
