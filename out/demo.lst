   491 34B7 A0 04			ldy #Spr_Y_Pos
   492 34B9 B1 88			lda (Ptr_Lo),y
   493 34BB C9 D1			cmp #$D1
   494 34BD 90 13			bcc Y_Done
   495 34BF A9 00			lda #$00
   496 34C1 A0 04			ldy #Spr_Y_Pos
