   199 3300			.proc Check_RAMTOP
   200 				; Disable BASIC
   201 3300-33A2> A9 C0			lda #$C0							; Check if RAMTOP is already OK
   202 3302 C5 6A			cmp RAMTOP							; Prevent flickering if BASIC is already off
   203 3304 F0 38			beq Ram_Ok
   204
   205 3306 A9 01			lda #$01							; Set BASICF for OS
   206 3308 8D F8 03			sta BASICF							; so BASIC remains OFF after RESET
   207
   208 330B AD 01 D3			lda PORTB							; Disable BASIC bit in PORTB for MMU
   209 330E 09 02			ora #$02							; by Setting bit 2
   210 3310 8D 01 D3			sta PORTB
   211
   212 3313 AD 00 A0			lda $A000							; Check if BASIC ROM area is now RAM
   213 3316 EE 00 A0			inc $A000							; This will also catch SDX not launching
   214 3319 CD 00 A0			cmp $A000							; the app via X
   215 331C F0 21			beq Ram_Not_Ok						; If not, perform print error and exit
   216
   217 331E A9 0C			lda #$0C							; 12 = CLOSE
   218 3320 20 2E 33			jsr Do_CIOV							; Close editor
