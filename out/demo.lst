   727 360A AD 53 D6			lda VBXE_BLITTER_BUSY
   728 360D D0 FB			bne Draw_Sprite_L1					; Wait for blitter idle
   729 360F A9 01			lda #$01
   730 3611 8D 53 D6			sta VBXE_BLITTER_START				; Fire
   731 3614 60				rts
