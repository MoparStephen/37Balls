   801 366D A9 00			lda #$00
   802 366F 8D 52 D6			sta VBXE_BL_ADR2					; See the description of BCB at the end of this
   803 3672 A9 05			lda #$05							; Source
   804 3674 8D 51 D6			sta VBXE_BL_ADR1
   805 3677 A9 00			lda #$00
   806 3679			Setup_Cmap1_L1
   807 3679 AD 53 D6			lda VBXE_BLITTER_BUSY
   808 367C C9 00			cmp #$00
   809 367E D0 F9			bne Setup_Cmap1_L1					; Wait for blitter to finish
   810 3680 A9 01			lda #$01
   811 3682 8D 53 D6			sta VBXE_BLITTER_START				; Start the blit
   812 3685 60				rts
