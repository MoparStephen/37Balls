   293 3394 A9 00			lda #$00
   294 3396 85 4D			sta ATRACT							; Disable screensaver
   295 3398 AD FC 02			lda CH
   296 339B C9 2F			cmp #$2F							; Press Q to quit
   297 339D F0 07			beq	Exit
   298 339F C9 21			cmp #$21							; Press Space to start
   299 33A1 D0 F1			bne Wait_Space_0
   300 33A3			Dont_Wait_Space_0
   301 33A3 4C 78 33			jmp Main_Loop						; Animate forever
   302
   303 				; This is where we exit
   304 33A6			Exit
   305 33A6 A9 FF			lda #$FF
   306 33A8 8D FC 02			sta CH								; Clear last key pressed
   307
   308 33AB A9 00			lda	#0
   309 33AD 8D 40 D6			sta	VBXE_VIDEO_CONTROL				; Disable XDL
   310 33B0 A9 00			lda	#0
   311 33B2 8D 5F D6			sta	VBXE_MA_BSEL					; Restore main memory (and disable VBXE memory window at VBXE_WINDOW)
   312
   313 33B5 6C 0A 00			jmp	(DOSVEC)						; Good bye ;)
