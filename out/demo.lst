   804 				;-----------------------------------------------------------------------------
   805 				; Generate_Colour_Map
   806 				; This will generate the 9600 byte colour map used by the VBXE
   807 				;-----------------------------------------------------------------------------
   808 3750			Generate_Colour_Map
   809 3750 A9 00			lda #$00
   810 3752 85 88			sta Ptr_Lo
   811 3754 A9 06			lda #$06
   812 3756 85 89			sta Ptr_Hi							; Initialize destination pointer to $0600
   813
   814 3758 A9 01			lda #$01
   815 375A 85 80			sta Reg1							; Running colour accumulator
   816
   817 375C A2 00			ldx #$00							; Object counter (0-15)
   818 375E			obj_loop
   819 375E A0 00			ldy #$00							; Row counter (0-14)
   820 3760			row_loop
   821 3760 A9 00			lda #$00							; Default: blank row
   822 3762 C0 00			cpy #$00
   823 3764 F0 08			beq store_colour
   824 3766 C0 0E			cpy #$0E
   825 3768 F0 04			beq store_colour
   826 376A A5 80			lda Reg1							; Non-blank row: use accumulator
   827 376C E6 80			inc Reg1
   828 376E			store_colour
   829 376E 91 88			sta (Ptr_Lo),Y
   830
   831 3770 C8				iny
   832 3771 C0 0F			cpy #$0F							; 15 rows per object
   833 3773 D0 EB			bne row_loop
   834
   835 				; Advance pointer by 15 to next object's base
   836 3775 A5 88			lda Ptr_Lo
   837 3777 18				clc
   838 3778 69 0F			adc #$0F
   839 377A 85 88			sta Ptr_Lo
   840 377C 90 02			bcc no_carry
   841 377E E6 89			inc Ptr_Hi
   842 3780			no_carry
   843 3780 E8				inx
   844 3781 E0 10			cpx #$10							; 16 objects
   845 3783 D0 D9			bne obj_loop
