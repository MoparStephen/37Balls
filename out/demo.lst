   675 35BF A9 00			lda	#0
   676 35C1 8D 52 D6			sta	VBXE_BL_ADR2					; See the description of BCB at the end of this
   677 35C4 A9 05			lda	#$05							; Source
   678 35C6 8D 51 D6			sta	VBXE_BL_ADR1
   679 35C9 A9 00			lda	#0
