   110 				;-----------------------------------------------------------------------------
   111 				;vblda	- loads accumulator with VBXE register value
   112 				;	  use:	vblda	VBXE_REGISTER
   113
   114 				vblda	.macro
   115 				.ifdef	__VBXE_AUTO__
   116 					lda VBXEBase+1
   117 					sta vblda_adr
   118 					lda.w :1
   119 				vblda_adr	equ *-1
   120 				.else
   121 					lda :1
   122 				.endif
   123 				.endm
   124
   125 				;-----------------------------------------------------------------------------
   126 				;vbsta	- stores accumulator in VBXE register
   127 				;	  use:	vbvbsta	VBXE_REGISTER
   128
   129 				vbsta	.macro
   130 				.ifdef	__VBXE_AUTO__
   131 					pha
   132 					lda VBXEBase+1
   133 					sta vbsta_adr
   134 					pla
   135 					sta.w :1
   136 				vbsta_adr	equ *-1
   137 				.else
   138 					sta.w :1
   139 				.endif
   140 				.endm
