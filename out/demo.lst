   746 				;-----------------------------------------------------------------------------
   747 				; Handle_Keys
   748 				;-----------------------------------------------------------------------------
   749 3623			Handle_Keys
   750 				; If present, the next lines will allow a "jump to exit" on a specific key press
   751 3623 AD FC 02			lda CH
   752 3626 C9 2F			cmp #$2F							; Press Q to quit
   753 3628 F0 1D			beq Exit_Long
   754 362A C9 32			cmp #$32							; 0
   755 362C F0 07			beq Handle_0
   756 362E C9 1F			cmp #$1F							; 1
   757 3630 F0 09			beq Handle_1
   758 3632			Handle_Keys_Done						; No more keys to test
   759 3632 4C 41 36			jmp Read_Key_Done
   760
   761 3635			Handle_0
   762 3635 20 96 35			jsr Toggle_Colour_Map				; Toggle the Colour Map (Attribute XDL) on/off
   763 3638 4C 41 36			jmp Read_Key_Done
   764
   765 363B			Handle_1
   766 363B 20 A3 35			jsr Toggle_Colour_Map_Values		; Toggle the Colour Map Byte 4 from $00 to $50
   767 363E 4C 41 36			jmp Read_Key_Done					; That is, set PFPAL and OVPAL to 0 or 1
   768
   769 3641			Read_Key_Done
   770 3641 A9 FF			lda #$FF
   771 3643 8D FC 02			sta CH								; Clear last key pressed
   772 3646 60				rts									; Else return to caller
   773 3647			Exit_Long
   774 3647 4C 11 32			jmp Cleanup_Exit					; Fix for branch out of range
   775
   776 				;-----------------------------------------------------------------------------
   777 				; Clear_Screen via blitter
   778 				;-----------------------------------------------------------------------------
   779 364A			Clear_Screen
   780 364A A9 15			lda #BLT_BAKGRND-BLT_BALL
   781 364C 8D 50 D6			sta VBXE_BL_ADR0					; Setup the blitter for memory fill operation
   782 364F A9 00			lda #$00
   783 3651 8D 52 D6			sta VBXE_BL_ADR2					; See the description of BCB at the end of this
   784 3654 A9 05			lda #$05							; Source
   785 3656 8D 51 D6			sta VBXE_BL_ADR1
   786 3659 A9 00			lda #$00
   787 365B			Clear_Screen_L1
   788 365B AD 53 D6			lda VBXE_BLITTER_BUSY
   789 365E C9 00			cmp #$00
   790 3660 D0 F9			bne Clear_Screen_L1					; Wait for blitter to finish
   791 3662 A9 01			lda #$01
   792 3664 8D 53 D6			sta VBXE_BLITTER_START				; Start the blit
   793 3667 60				rts
   794
   795 				;-----------------------------------------------------------------------------
