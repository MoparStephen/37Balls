   314
   315 33B3 A9 00			lda #$00
   316 33B5 8D 40 D6			sta VBXE_VIDEO_CONTROL				; Disable XDL
   317 33B8 A9 00			lda #$00
   318 33BA 8D 5F D6			sta VBXE_MA_BSEL					; Restore main memory (and disable VBXE memory window at VBXE_WINDOW)
   319
   320 33BD 6C 0A 00			jmp (DOSVEC)						; Good bye ;)
