   357 				;-----------------------------------------------------------------------------
   358 				; Set_Positions
   359 				; For each sprite: update position with sub-pixel accuracy, bounce off walls,
   360 				; compute VBXE address via Calculate_200, write to BLT_BALL BCB, fire blitter.
   361 				; X = object counter,  Ptr_Lo/Ptr_Hi = pointer to current Sprite struct
   362 				;-----------------------------------------------------------------------------
   363 33EC			Set_Positions
   364 33EC A9 80			lda	#$80
   365 33EE 8D 5F D6			sta	VBXE_MA_BSEL					; Enable VBXE window for BCB writes
   366
   367 33F1 A9 00			lda	#<Bobs
   368 33F3 85 88			sta	Ptr_Lo
   369 33F5 A9 55			lda	#>Bobs
   370 33F7 85 89			sta	Ptr_Hi
   371 33F9 A2 00			ldx	#0
   372
   373 33FB			Spr_Loop
   374 33FB A5 8A			lda Do_Motion
   375 33FD D0 03			bne Set_X
   376 33FF 4C CA 34			jmp	Skip_Motion						; Long branch fix
   377
   378 				;--- X motion ----------------------------------------------------------------
   379 3402			Set_X
   380 3402 18				clc
   381 3403 A0 00			ldy	#Spr_X_Pos_Frac
   382 3405 B1 88			lda	(Ptr_Lo),y
   383 3407 A0 06			ldy	#Spr_Delta_X_Frac
   384 3409 71 88			adc	(Ptr_Lo),y
   385 340B A0 00			ldy	#Spr_X_Pos_Frac
   386 340D 91 88			sta	(Ptr_Lo),y
   387
   388 340F A0 01			ldy	#Spr_X_Pos_Lo
   389 3411 B1 88			lda	(Ptr_Lo),y
   390 3413 A0 07			ldy	#Spr_Delta_X
   391 3415 71 88			adc	(Ptr_Lo),y
   392 3417 A0 01			ldy	#Spr_X_Pos_Lo
   393 3419 91 88			sta	(Ptr_Lo),y
   394
   395 341B A0 02			ldy	#Spr_X_Pos_Hi
   396 341D B1 88			lda	(Ptr_Lo),y
   397 341F A0 05			ldy	#Spr_Delta_X_Sign
   398 3421 71 88			adc	(Ptr_Lo),y						; $00 = right, $FF = left
   399 3423 A0 02			ldy	#Spr_X_Pos_Hi
   400 3425 91 88			sta	(Ptr_Lo),y
   401 3427 B1 88			lda	(Ptr_Lo),y						; Reload to restore N flag (sta does not set N)
   402
   403 				; Left wall: X_Pos_Hi >= $80 means position underflowed past 0
   404 3429 10 1A			bpl	X_Check_Right
   405 342B A9 00			lda	#$00
   406 342D A0 02			ldy	#Spr_X_Pos_Hi
   407 342F 91 88			sta	(Ptr_Lo),y
   408 3431 A0 01			ldy	#Spr_X_Pos_Lo
   409 3433 91 88			sta	(Ptr_Lo),y
   410 3435 A0 00			ldy	#Spr_X_Pos_Frac
   411 3437 91 88			sta	(Ptr_Lo),y
   412 3439 A0 05			ldy	#Spr_Delta_X_Sign
   413 343B B1 88			lda	(Ptr_Lo),y
   414 343D 10 33			bpl	X_Done							; Already heading right
   415 343F 20 B8 33			jsr	Reverse_X
   416 3442 4C 72 34			jmp	X_Done
   417
   418 				; Right wall: clamp if X_Pos > $0120 (320 - 32 = 288)
   419 3445			X_Check_Right
   420 3445 A0 02			ldy	#Spr_X_Pos_Hi
   421 3447 B1 88			lda	(Ptr_Lo),y
   422 3449 C9 01			cmp	#$01
   423 344B 90 25			bcc	X_Done							; Hi < $01, in range
   424 344D D0 08			bne	X_Hit_Right						; Hi > $01, past right edge
   425 344F A0 01			ldy	#Spr_X_Pos_Lo
   426 3451 B1 88			lda	(Ptr_Lo),y
   427 3453 C9 21			cmp	#$21							; Lo > $20?
   428 3455 90 1B			bcc	X_Done
   429 3457			X_Hit_Right
   430 3457 A9 01			lda	#$01
   431 3459 A0 02			ldy	#Spr_X_Pos_Hi
   432 345B 91 88			sta	(Ptr_Lo),y
   433 345D A9 20			lda	#$20
   434 345F A0 01			ldy	#Spr_X_Pos_Lo
   435 3461 91 88			sta	(Ptr_Lo),y
   436 3463 A9 00			lda	#$00
   437 3465 A0 00			ldy	#Spr_X_Pos_Frac
   438 3467 91 88			sta	(Ptr_Lo),y
   439 3469 A0 05			ldy	#Spr_Delta_X_Sign
   440 346B B1 88			lda	(Ptr_Lo),y
   441 346D 30 03			bmi	X_Done							; Already heading left
   442 346F 20 B8 33			jsr	Reverse_X
   443 3472			X_Done
   444
   445 				;--- Y motion ----------------------------------------------------------------
   446 3472 18				clc
   447 3473 A0 03			ldy	#Spr_Y_Pos_Frac
   448 3475 B1 88			lda	(Ptr_Lo),y
   449 3477 A0 09			ldy	#Spr_Delta_Y_Frac
   450 3479 71 88			adc	(Ptr_Lo),y
   451 347B A0 03			ldy	#Spr_Y_Pos_Frac
   452 347D 91 88			sta	(Ptr_Lo),y
   453
   454 347F A0 04			ldy	#Spr_Y_Pos
   455 3481 B1 88			lda	(Ptr_Lo),y
   456 3483 A0 0A			ldy	#Spr_Delta_Y
   457 3485 71 88			adc	(Ptr_Lo),y
   458 3487 A0 04			ldy	#Spr_Y_Pos
   459 3489 91 88			sta	(Ptr_Lo),y
   460
   461 348B A0 08			ldy	#Spr_Delta_Y_Sign
   462 348D B1 88			lda	(Ptr_Lo),y
   463 348F 30 1E			bmi	Y_Check_Top
   464
   465 				; Moving down: clamp if Y_Pos > $D0 (240 - 32 = 208)
   466 3491			Y_Check_Bottom
   467 3491 A0 04			ldy	#Spr_Y_Pos
   468 3493 B1 88			lda	(Ptr_Lo),y
   469 3495 C9 D1			cmp	#$D1
   470 3497 90 31			bcc	Y_Done
   471 3499 A9 D0			lda	#$D0
   472 349B 91 88			sta	(Ptr_Lo),y
   473 349D A9 00			lda	#$00
   474 349F A0 03			ldy	#Spr_Y_Pos_Frac
   475 34A1 91 88			sta	(Ptr_Lo),y
   476 34A3 A0 08			ldy	#Spr_Delta_Y_Sign
   477 34A5 B1 88			lda	(Ptr_Lo),y
   478 34A7 30 21			bmi	Y_Done							; Already heading up
   479 34A9 20 D2 33			jsr	Reverse_Y
   480 34AC 4C CA 34			jmp	Y_Done
   481
   482 				; Moving up: underflow wraps Y_Pos above $D0
   483 34AF			Y_Check_Top
   484 34AF A0 04			ldy	#Spr_Y_Pos
   485 34B1 B1 88			lda	(Ptr_Lo),y
   486 34B3 C9 D1			cmp	#$D1
   487 34B5 90 13			bcc	Y_Done
   488 34B7 A9 00			lda	#$00
   489 34B9 A0 04			ldy	#Spr_Y_Pos
   490 34BB 91 88			sta	(Ptr_Lo),y
   491 34BD A0 03			ldy	#Spr_Y_Pos_Frac
   492 34BF 91 88			sta	(Ptr_Lo),y
   493 34C1 A0 08			ldy	#Spr_Delta_Y_Sign
   494 34C3 B1 88			lda	(Ptr_Lo),y
   495 34C5 10 03			bpl	Y_Done							; Already heading down
   496 34C7 20 D2 33			jsr	Reverse_Y
   497 34CA			Y_Done
   498
   499 				;--- Compute VBXE address and blit -------------------------------------------
   500 34CA			Skip_Motion								; Jump here to bypass ball motion
   501 34CA A0 01			ldy	#Spr_X_Pos_Lo
   502 34CC B1 88			lda	(Ptr_Lo),y
   503 34CE 85 80			sta	Reg1							; X_Pos_Lo â†’ Calculate_200 input
   504 34D0 A0 02			ldy	#Spr_X_Pos_Hi
   505 34D2 B1 88			lda	(Ptr_Lo),y
   506 34D4 85 81			sta	Reg2							; X_Pos_Hi â†’ Calculate_200 input
   507 34D6 A0 04			ldy	#Spr_Y_Pos
   508 34D8 B1 88			lda	(Ptr_Lo),y
   509 34DA 85 82			sta	Reg3							; Y_Pos    â†’ Calculate_200 input
   510
   511 34DC 20 14 36			jsr	Calculate_200					; â†’ Reg4=Adr0, Reg5=Adr1, Reg6=Adr2
   512
   513 34DF A5 83			lda	Reg4
   514 34E1 8D 06 25			sta	VBXE_WINDOW+$500+BLT_BALL-BLT_BALL+Dest_Adr0
   515 34E4 A5 84			lda	Reg5
   516 34E6 8D 07 25			sta	VBXE_WINDOW+$500+BLT_BALL-BLT_BALL+Dest_Adr1
   517 34E9 A5 85			lda	Reg6
   518 34EB 8D 08 25			sta	VBXE_WINDOW+$500+BLT_BALL-BLT_BALL+Dest_Adr2
   519
   520 34EE 20 8B 35			jsr	Draw_Sprite						; Wait for blitter idle then fire BLT_BALL
   521
   522 				;--- Advance Ptr to next sprite ----------------------------------------------
   523 34F1 18				clc
   524 34F2 A5 88			lda	Ptr_Lo
   525 34F4 69 0B			adc	#Sprite_Size
   526 34F6 85 88			sta	Ptr_Lo
   527 34F8 90 02			bcc	No_Hi_Bump
   528 34FA E6 89			inc	Ptr_Hi
   529 34FC			No_Hi_Bump
   530 34FC E8				inx
   531 34FD E4 8B			cpx	Num_Sprites
   532 34FF F0 03			beq	Spr_Loop_Done					; All sprites done
   533 3501 4C FB 33			jmp	Spr_Loop						; Long branch workaround (loop body > 127 bytes)
   534 3504			Spr_Loop_Done
   535 3504 A9 00			lda	#$00
   536 3506 8D 5F D6			sta	VBXE_MA_BSEL					; Disable VBXE window
   537 3509 60				rts
