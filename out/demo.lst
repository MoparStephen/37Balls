   147 				;VBXE_Detect - detects VBXE FX core version 1.07 and above,
   148 				; and stores VBXE Base address in VBXEBase
   149 3139			VBXE_Detect
   150 3139 A9 00			lda #$00
   151 313B A2 D6			ldx #$D6
   152 313D 8D 40 D6			sta $D640							; Make sure it isn't coincidence
   153 3140 AD 40 D6			lda $D640
   154 3143 C9 10			cmp #$10							; Do we have major version here?
   155 3145 F0 15			beq VBXE_Detected					; If so, then VBXE is detected
   156 3147 A9 00			lda #$00
   157 3149 E8				inx
   158 314A 8D 40 D7			sta $D740							; No such luck, try other location
   159 314D AD 40 D7			lda $D740
   160 3150 C9 10			cmp #$10
   161 3152 F0 08			beq VBXE_Detected
   162 3154 A2 00			ldx #$00							; Not here, so not present or FX core version too low
   163 3156 86 92			stx VBXEBase+1
   164 3158 86 91			stx VBXEBase
   165 315A 38				sec
   166 315B 60				rts
   167 315C			VBXE_Detected:
   168 315C 86 92			stx VBXEBase+1
   169 315E A9 00			lda #$00
   170 3160 85 91			sta VBXEBase
   171 3162				vblda VBXE_MINOR					; Get core minor version
