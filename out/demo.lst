   368 				; Set the base address of MEMA window to VBXE_WINDOW
   369 				; Size to 4k and accesible only by CPU
   370 331D A9 28			lda #>VBXE_WINDOW + 8
   371 331F 8D 5E D6			sta VBXE_MA_CTL
   372
   373 3322 A9 80			lda #$00 | MEMAC_GLOBAL_ENABLE		; Bank $00 VBXE Window Enabled
   374 3324 8D 5F D6			sta VBXE_MA_BSEL
   375
   376 					; Copy blit to VBXE memory
   377 3327 A2 14			ldx #$14
   378 3329 BD 4D 33 9D 00 20 + 	mva:rpl blit_clear,x VBXE_WINDOW,x-
   379
   380 					; Kick blit
   381 3332 A9 00			lda #$00
   382 3334 8D 50 D6			sta VBXE_BL_ADR0
   383 3337 8D 51 D6			sta VBXE_BL_ADR1
   384 333A 8D 52 D6			sta VBXE_BL_ADR2
   385 333D A9 01			lda #$01
   386 333F 8D 53 D6			sta VBXE_BLITTER_START				; Start the blit
   387
   388 					; Wait for blit complete
   389 3342 AD 53 D6 D0 FB		lda:rne VBXE_BLITTER_BUSY
   390
   391 3347 A9 00			lda #MEMAC_GLOBAL_DISABLE			; USE CPU address space
   392 3349 8D 5F D6			sta VBXE_MA_BSEL
