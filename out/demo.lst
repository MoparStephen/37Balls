   635 				;-----------------------------------------------------------------------------
   636 				; Draw_Sprite - fire BLT_BALL; destination already written to BCB by Set_Positions
   637 				;-----------------------------------------------------------------------------
   638 358B			Draw_Sprite
   639 358B A9 00			lda	#BLT_BALL-BLT_BALL
   640 358D 8D 50 D6			sta	VBXE_BL_ADR0
   641 3590 A9 00			lda	#$00
   642 3592 8D 52 D6			sta	VBXE_BL_ADR2
   643 3595 A9 05			lda	#$05
   644 3597 8D 51 D6			sta	VBXE_BL_ADR1
   645 359A			Draw_Sprite_L1
   646 359A AD 53 D6			lda	VBXE_BLITTER_BUSY
   647 359D D0 FB			bne	Draw_Sprite_L1					; Wait for blitter idle
   648 359F A9 01			lda	#1
