   197 				; Step $02 - Ensure RAMTOP is = $C0 and no BASIC cart/ROM is present
   198 					org LOAD_ADDRESS + $300
   199 3300			.proc Check_RAMTOP
   200 				; Disable BASIC
   201 3300-33A2> A9 C0			lda #$C0							; Check if RAMTOP is already OK
   202 3302 C5 6A			cmp RAMTOP							; Prevent flickering if BASIC is already off
   203 3304 F0 38			beq Ram_Ok
   204
   205 3306 A9 01			lda #$01							; Set BASICF for OS
   206 3308 8D F8 03			sta BASICF							; So BASIC remains OFF after RESET
   207
   208 330B AD 01 D3			lda PORTB							; Disable BASIC bit in PORTB for MMU
   209 330E 09 02			ora #$02							; By Setting bit 2
   210 3310 8D 01 D3			sta PORTB
   211
   212 3313 AD 00 A0			lda $A000							; Check if BASIC ROM area is now RAM
   213 3316 EE 00 A0			inc $A000							; This will also catch SDX not launching
   214 3319 CD 00 A0			cmp $A000							; The app via X
   215 331C F0 21			beq Ram_Not_Ok						; If not, perform print error and exit
   216
   217 331E A9 0C			lda #$0C							; 12 = CLOSE
   218 3320 20 2E 33			jsr Do_CIOV							; Close editor
   219
   220 3323 A9 C0			lda #$C0
   221 3325 85 6A			sta RAMTOP							; Set RAMTOP to end of BASIC
   222 3327 8D E4 02			sta RAMSIZ							; Set RAMSIZ also
   223
   224 332A A2 00			ldx #$00							; Channel #0
   225 332C A9 04			lda #$04							; 4 = OPEN_READ
   226 332E			Do_CIOV
   227 332E 8D 42 03			sta ICCOM							; Store the Command
   228 3331 A9 68			lda #<Device_Name
   229 3333 8D 44 03			sta ICBAL							; Use channel #0
   230 3336 A9 33			lda #>Device_Name
   231 3338 8D 45 03			sta ICBAH
   232 333B 20 56 E4			jsr CIOV
   233
   234 333E			Ram_Ok
   235 333E 60				rts
   236
   237 333F			Ram_Not_Ok								; Add your error handling here, there still is a ROM....
   238 333F A0 42			ldy #$42							; Dark Red
   239 3341 8C C6 02			sty COLOR2							; Set playfield
   240
   241 				; Print RAM_Failure_Message - line 3 (y = $79)
