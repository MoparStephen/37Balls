   737 3615 2C 0B D4			bit VCOUNT
   738 3618 30 FB			bmi *-3
   739 361A 2C 0B D4			bit VCOUNT
   740 361D 10 FB			bpl *-3
   741
   742 361F 20 23 36			jsr Handle_Keys						; Take care of user input
   743
   744 3622 60				rts									; Else return to caller
