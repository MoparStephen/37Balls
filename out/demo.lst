   384
   385 				;--- X motion ----------------------------------------------------------------
   386 340A			Set_X
   387 340A 18				clc
   388 340B A0 00			ldy #Spr_X_Pos_Frac
   389 340D B1 88			lda (Ptr_Lo),y
   390 340F A0 06			ldy #Spr_Delta_X_Frac
   391 3411 71 88			adc (Ptr_Lo),y
   392 3413 A0 00			ldy #Spr_X_Pos_Frac
   393 3415 91 88			sta (Ptr_Lo),y
   394
   395 3417 A0 01			ldy #Spr_X_Pos_Lo
   396 3419 B1 88			lda (Ptr_Lo),y
   397 341B A0 07			ldy #Spr_Delta_X
   398 341D 71 88			adc (Ptr_Lo),y
   399 341F A0 01			ldy #Spr_X_Pos_Lo
   400 3421 91 88			sta (Ptr_Lo),y
   401
   402 3423 A0 02			ldy #Spr_X_Pos_Hi
   403 3425 B1 88			lda (Ptr_Lo),y
   404 3427 A0 05			ldy #Spr_Delta_X_Sign
   405 3429 71 88			adc (Ptr_Lo),y						; $00 = right, $FF = left
   406 342B A0 02			ldy #Spr_X_Pos_Hi
   407 342D 91 88			sta (Ptr_Lo),y
   408 342F B1 88			lda (Ptr_Lo),y						; Reload to restore N flag (sta does not set N)
   409
   410 				; Left wall: X_Pos_Hi >= $80 means position underflowed past 0
   411 3431 10 1A			bpl X_Check_Right
   412 3433 A9 00			lda #$00
   413 3435 A0 02			ldy #Spr_X_Pos_Hi
   414 3437 91 88			sta (Ptr_Lo),y
   415 3439 A0 01			ldy #Spr_X_Pos_Lo
   416 343B 91 88			sta (Ptr_Lo),y
   417 343D A0 00			ldy #Spr_X_Pos_Frac
   418 343F 91 88			sta (Ptr_Lo),y
   419 3441 A0 05			ldy #Spr_Delta_X_Sign
   420 3443 B1 88			lda (Ptr_Lo),y
   421 3445 10 33			bpl X_Done							; Already heading right
   422 3447 20 C0 33			jsr Reverse_X
   423 344A 4C 7A 34			jmp X_Done
   424
   425 				; Right wall: clamp if X_Pos > $0120 (320 - 32 = 288)
   426 344D			X_Check_Right
   427 344D A0 02			ldy #Spr_X_Pos_Hi
   428 344F B1 88			lda (Ptr_Lo),y
   429 3451 C9 01			cmp #$01
   430 3453 90 25			bcc X_Done							; Hi < $01, in range
   431 3455 D0 08			bne X_Hit_Right						; Hi > $01, past right edge
   432 3457 A0 01			ldy #Spr_X_Pos_Lo
   433 3459 B1 88			lda (Ptr_Lo),y
   434 345B C9 21			cmp #$21							; Lo > $20?
   435 345D 90 1B			bcc X_Done
   436 345F			X_Hit_Right
   437 345F A9 01			lda #$01
   438 3461 A0 02			ldy #Spr_X_Pos_Hi
   439 3463 91 88			sta (Ptr_Lo),y
   440 3465 A9 20			lda #$20
   441 3467 A0 01			ldy #Spr_X_Pos_Lo
   442 3469 91 88			sta (Ptr_Lo),y
   443 346B A9 00			lda #$00
   444 346D A0 00			ldy #Spr_X_Pos_Frac
   445 346F 91 88			sta (Ptr_Lo),y
   446 3471 A0 05			ldy #Spr_Delta_X_Sign
   447 3473 B1 88			lda (Ptr_Lo),y
   448 3475 30 03			bmi X_Done							; Already heading left
   449 3477 20 C0 33			jsr Reverse_X
   450 347A			X_Done
