   874 37AC AD 5B 25			lda VBXE_WINDOW+$554+$07			; Dest Addr 1
   875 37AF 69 01			adc #$01
   876 37B1 8D 5B 25			sta VBXE_WINDOW+$554+$07			; Dest Addr 1
   877
   878 37B4 AD 5C 25			lda VBXE_WINDOW+$554+$08			; Dest Addr 0
   879 37B7 69 00			adc #$00
   880 37B9 8D 5C 25			sta VBXE_WINDOW+$554+$08			; Dest Addr 1
