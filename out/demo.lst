    51 				.zpvar Ptr_Lo			.byte			; Lo byte of pointer
    52 				.zpvar Ptr_Hi			.byte			; Hi byte of pointer
    53 				.zpvar Do_Motion		.byte			; Allows pausing motion for the initial start
    54 				.zpvar Num_Sprites		.byte			; Keeps track of the number of sprites we are displaying
