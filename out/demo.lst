   711 35F6 A9 54			lda	#BLT_SETUP_CMAP_2-BLT_BALL
   712 35F8 8D 50 D6			sta	VBXE_BL_ADR0					; Setup the blitter for memory fill operation
   713 35FB A9 00			lda	#0
   714 35FD 8D 52 D6			sta	VBXE_BL_ADR2					; See the description of BCB at the end of this
   715 3600 A9 05			lda	#$05							; Source
