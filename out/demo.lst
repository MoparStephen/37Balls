   261 3362 8D 05 24			sta VBXE_WINDOW + $405				; XDL Adr2 (byte 5 of XDL at VBXE_WINDOW+$400)
   262
   263 3365 A9 64			lda #$64							; Delay animation starting by $64 frames (2 PAL seconds)
   264 3367 85 80			sta Reg1
   265
   266 3369			Delay_Start
   267 3369 20 03 44			jsr music.play						; Play a frame of music
   268 336C 20 15 36			jsr Wait_For_Sync
