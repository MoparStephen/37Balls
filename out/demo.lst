     1 2500			BLT_BALL
     2 2500-2568> 00 00 01		dta $00,$00,$01						; Source address
     3 2503 20 00			dta $20,$00							; Source step y
     4 2505 01				dta $01								; Source step x
     5 2506 00 00 02			dta $00,$00,$02						; Destination address
     6 2509 00 02			dta $00,$02							; Destination step y
     7 250B 01				dta $01								; Destination step x
     8 250C 1F 00			dta $1F,$00							; Width
     9 250E 1F				dta $1F								; Height
    10 250F FF				dta $FF								; And mask
    11 2510 00				dta $00								; Xor mask
    12 2511 00				dta $00								; Collision and mask
    13 2512 00				dta $00								; Zoom
    14 2513 00				dta $00								; Pattern feature
    15 2514 01				dta $01								; Control
    16
    17 2515			BLT_BAKGRND
    18 2515 00 00 00			dta $00,$00,$00						; Source address
    19 2518 00 00			dta $00,$00							; Source step y
    20 251A 00				dta $00								; Source step x
    21 251B 00 00 02			dta $00,$00,$02						; Destination address
    22 251E 00 02			dta $00,$02							; Destination step y
    23 2520 01				dta $01								; Destination step x
    24 2521 27 00			dta $27,$00							; Width
    25 2523 1D				dta $1d								; Height
    26 2524 00				dta $00								; And mask (and mask equal to 0, memory will be filled with xor mask)
    27 2525 00				dta $00								; Xor mask
    28 2526 00				dta $00								; Collision and mask
    29 2527 77				dta $77								; Zoom
    30 2528 00				dta $00								; Patter feature
    31 2529 00				dta $00								; Control
    32
    33 				; Clear 496kB (leave bottom 16kB for the SVBXE.SYS driver)
    34 				; 496x16 zoom 8x8 clear blit (this takes 2 frames)
    35 252A			BLT_CLEAR
    36 252A 00 00 00			dta $00,$00,$00						; Source address
    37 252D 00 00			dta $00,$00							; Source step y
    38 252F 00				dta $00								; Source step x
    39 2530 FF BF 07			dta $FF,$BF,$07						; Destination address
    40 2533 80 F0			dta a(-$0F80)						; Destination step y (backwards 3968 bytes) - NOTE: this equals 496 * zoom factor of 8
    41 2535 FF				dta -$01							; Destination step x (backwards	1 byte)
    42 2536 EF 01			dta $EF,$01							; Width-1  (495)	496 * 8 bytes wide
    43 2538 0F				dta $0F								; Height-1 (15)		 16 * 8 bytes high
    44 2539 00				dta $00								; And mask (And mask equal to 0 so clear)
    45 253A 00				dta $00								; Xor mask (will be filled with xor mask)
    46 253B 00				dta $00								; Collision and mask
    47 253C 77				dta $77								; Zoom (BLT_ZOOMY = 7, BLT_ZOOMX = 7 so 8Y*8X)
    48 253D 00				dta $00								; Pattern feature
    49 253E 00				dta $00								; Control (Mode 0 with NEXT bit Cleared)
    50
    51 				; Fill the ColourMap area ($60000-$72BFF) with $50 every 4 bytes
    52 				; This sets up the Palette & Priority bytes for the entire Colour Map
    53 253F			BLT_SETUP_CMAP_1
    54 253F 00 00 00			dta $00,$00,$00						; Source address
    55 2542 00 00			dta $00,$00							; Source step y
    56 2544 00				dta $00								; Source step x
    57 2545 03 00 06			dta $03,$00,$06						; Destination address ($60003)
    58 2548 40 01			dta $40,$01							; Destination step y
    59 254A 04				dta $04								; Destination step x
    60 254B 3F 01			dta $3F,$01							; Width ($140)
    61 254D EF				dta $EF								; Height ($F0)
    62 254E 00				dta $00								; And mask
    63 254F 50				dta $50								; Xor mask
    64 2550 00				dta $00								; Collision and mask
    65 2551 00				dta $00								; Zoom
    66 2552 00				dta $00								; Pattern feature
    67 2553 00				dta $00								; Control
    68
    69 				; Fill the ColourMap area with a single line ($140 bytes) of
    70 				; Local substitute of the COLPF1 register (GTIA)
    71 				; This BCB gets modified before each call
    72 				; Starting address increments by $140 each time
    73 				; Xor mask pulls values from the temp table at $0600
    74 2554			BLT_SETUP_CMAP_2
    75 2554 00 00 00			dta $00,$00,$00						; Source address
    76 2557 00 00			dta $00,$00							; Source step y
    77 2559 00				dta $00								; Source step x
    78 255A 01 00 06			dta $01,$00,$06						; Destination address ($60001)
    79 255D 40 01			dta $40,$01							; Destination step y
    80 255F 04				dta $04								; Destination step x
    81 2560 27 00			dta $27,$00							; Width ($28)
    82 2562 00				dta $00								; Height ($01)
    83 2563 00				dta $00								; And mask
    84 2564 69				dta $69								; Xor mask
    85 2565 00				dta $00								; Collision and mask
    86 2566 00				dta $00								; Zoom
    87 2567 00				dta $00								; Pattern feature
    88 2568 00				dta $00								; Control
