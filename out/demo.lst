   559 351F A0 00			ldy	#Spr_X_Pos_Frac
   560 3521 91 88			sta	(Ptr_Lo),y
   561 3523 A0 02			ldy	#Spr_X_Pos_Hi
   562 3525 91 88			sta	(Ptr_Lo),y
   563
   564 					; Y position from table - Frac always 0
   565 3527 8A				txa
   566 3528 A8				tay
   567 3529 B9 90 37			lda	Init_Pos_Y,y
   568 352C A0 04			ldy	#Spr_Y_Pos
   569 352E 91 88			sta	(Ptr_Lo),y
   570 3530 A9 00			lda	#$00
   571 3532 A0 03			ldy	#Spr_Y_Pos_Frac
   572 3534 91 88			sta	(Ptr_Lo),y
   573
   574 					; Velocity from tables, indexed directly by object number
   575 3536 8A				txa
   576 3537 A8				tay
