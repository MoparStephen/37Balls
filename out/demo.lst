   330 33C0 38				sec
   331 33C1 A0 06			ldy #Spr_Delta_X_Frac
   332 33C3 A9 00			lda #$00
   333 33C5 F1 88			sbc (Ptr_Lo),y
   334 33C7 91 88			sta (Ptr_Lo),y
   335 33C9 A0 07			ldy #Spr_Delta_X
   336 33CB A9 00			lda #$00
   337 33CD F1 88			sbc (Ptr_Lo),y
   338 33CF 91 88			sta (Ptr_Lo),y
   339 33D1 A0 05			ldy #Spr_Delta_X_Sign
