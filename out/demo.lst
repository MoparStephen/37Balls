  1008 				;-----------------------------------------------------------------------------
  1009 				; Data Tables go here
  1010 				;-----------------------------------------------------------------------------
  1011 				; 37 velocity patterns - one per sprite, every (int,frac) pair unique
  1012 				; X: integer $00-$03 cycles with period 4; frac rotates +$40 each int group
  1013 				; Y: integer offset by 1 ($01-$03,$00); frac rotates +$20 relative to X â†’ no correlation
  1014 3767			Init_Delta_X
  1015 3767 01 01 02 03 00 01 + 	dta $01,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03
  1016 3777 00 01 02 03 00 01 + 	dta $00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03
  1017 3787 00 01 02 03 00		dta $00,$01,$02,$03,$00
  1018 378C			Init_Delta_X_Frac
  1019 378C 00 40 80 C0 10 50 + 	dta $00,$40,$80,$C0,$10,$50,$90,$D0,$20,$60,$A0,$E0,$30,$70,$B0,$F0
  1020 379C 40 80 C0 00 50 90 + 	dta $40,$80,$C0,$00,$50,$90,$D0,$10,$60,$A0,$E0,$20,$70,$B0,$F0,$30
  1021 37AC 80 C0 00 40 90		dta $80,$C0,$00,$40,$90
  1022 37B1			Init_Delta_Y
  1023 37B1 06 02 03 00 01 02 + 	dta $06,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$01,$01,$02,$03,$00
  1024 37C1 01 02 03 00 01 02 + 	dta $01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00
  1025 37D1 01 02 03 00 01		dta $01,$02,$03,$00,$01
  1026 37D6			Init_Delta_Y_Frac
  1027 37D6 00 60 A0 E0 30 70 + 	dta $00,$60,$A0,$E0,$30,$70,$B0,$F0,$40,$80,$C0,$00,$50,$90,$D0,$10
  1028 37E6 60 A0 E0 20 70 B0 + 	dta $60,$A0,$E0,$20,$70,$B0,$F0,$30,$80,$C0,$00,$40,$90,$D0,$10,$50
  1029 37F6 A0 E0 20 60 B0		dta $A0,$E0,$20,$60,$B0
  1030
  1031 				; Standard Atari ROM font for 3 and 7, laid out by hand, then auto-generated tables based on my grid
  1032 37FB			Init_Pos_X_Lo
  1033 37FB 12 24 36 48 5A 6C + 	dta $12,$24,$36,$48,$5A,$6C,$A2,$B4,$C6,$D8,$EA,$FC,$48,$5A,$A2,$EA	; Objs $00-$0F
  1034 380B FC 36 48 D8 EA 48 + 	dta $FC,$36,$48,$D8,$EA,$48,$5A,$C6,$D8,$12,$24,$5A,$6C,$B4,$C6,$24	; Objs $10-$1F
  1035 381B 36 48 5A B4 C6		dta $36,$48,$5A,$B4,$C6				; Objs $20-$24
  1036 3820			Init_Pos_Y
  1037 3820 0D 0D 0D 0D 0D 0D + 	dta $0D,$0D,$0D,$0D,$0D,$0D,$0D,$0D,$0D,$0D,$0D,$0D,$1A,$1A,$1A,$1A	; Objs $00-$0F
  1038 3830 1A 27 27 27 27 34 + 	dta $1A,$27,$27,$27,$27,$34,$34,$34,$34,$41,$41,$41,$41,$41,$41,$4E	; Objs $10-$1F
  1039 3840 4E 4E 4E 4E 4E		dta $4E,$4E,$4E,$4E,$4E				; Objs $20-$24
  1040
