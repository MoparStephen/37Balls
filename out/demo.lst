   364 				;-----------------------------------------------------------------------------
   365 				; Set_Positions
   366 				; For each sprite: update position with sub-pixel accuracy, bounce off walls,
   367 				; compute VBXE address via Calculate_200, write to BLT_BALL BCB, fire blitter.
   368 				; X = object counter,  Ptr_Lo/Ptr_Hi = pointer to current Sprite struct
   369 				;-----------------------------------------------------------------------------
   370 33F4			Set_Positions
   371 33F4 A9 80			lda #$80
   372 33F6 8D 5F D6			sta VBXE_MA_BSEL					; Enable VBXE window for BCB writes
   373
   374 33F9 A9 00			lda #<Bobs
   375 33FB 85 88			sta Ptr_Lo
   376 33FD A9 55			lda #>Bobs
   377 33FF 85 89			sta Ptr_Hi
   378 3401 A2 00			ldx #$00
   379
   380 3403			Spr_Loop
   381 3403 A5 8A			lda Do_Motion
