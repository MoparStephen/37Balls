   545 350A A9 00			lda	#<Bobs
   546 350C 85 88			sta	Ptr_Lo
   547 350E A9 55			lda	#>Bobs
   548 3510 85 89			sta	Ptr_Hi
   549 3512 A2 00			ldx	#0
   550
   551 3514			Init_Spr_L
   552 					; X position from tables - Frac always 0, Pos_Hi always 0
   553 3514 8A				txa
   554 3515 A8				tay
   555 3516 B9 6B 37			lda	Init_Pos_X_Lo,y
   556 3519 A0 01			ldy	#Spr_X_Pos_Lo
   557 351B 91 88			sta	(Ptr_Lo),y
