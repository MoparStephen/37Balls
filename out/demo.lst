   833 				;-----------------------------------------------------------------------------
   834 				; Calculate_200
   835 				;   Reg1 = X_Pos_L	Object Horizontal Position (Col)
   836 				;   Reg2 = X_Pos_H	Object Horizontal Position (Col)
   837 				;   Reg3 = Y_Pos	Object Vertical Position   (Row)
   838 				;   Reg4 = Adr0	   VBXE Blitter Address
   839 				;   Reg5 = Adr1	   VBXE Blitter Address
   840 				;   Reg6 = Adr2	   VBXE Blitter Address
   841 				;   Reg7 = XDL destination high byte (either 0 or 2)
   842 				;-----------------------------------------------------------------------------
   843 36A4			Calculate_200
   844 				; Because we are double buffering, we need to write to the backbuffer
   845 				; So load the buffer address from the XDL but use the other one
   846 36A4 AD 5F D6			lda VBXE_MA_BSEL
   847 36A7 48				pha									; Store it
   848
   849 36A8 A9 80			lda #$80							; Bank $00 with global enable (XDL lives in bank $00)
   850 36AA 8D 5F D6			sta VBXE_MA_BSEL
   851
   852 36AD AD 05 24			lda VBXE_WINDOW + $405				; XDL Adr2 (byte 5 of XDL at VBXE_WINDOW+$400)
   853 36B0 49 06			eor #$06							; Flip between $02 ($020000) and $04 ($040000)
   854 36B2 85 86			sta Reg7							; Reg7 = backbuffer Adr2
   855
   856 				; Calculate the start of VRAM (Reg4, Reg5, Reg6) for the given Y-Pos
   857 36B4 A9 00			lda #$00
   858 36B6 85 83			sta Reg4							; Reset to initial value
   859 36B8 85 85			sta Reg6							; Reset to initial value
   860 36BA A5 82			lda Reg3							; Y_Pos
   861 36BC 10 04			bpl Skip_Reg6						; If A <= $7F Reg6 will be 0
   862 36BE A0 01			ldy #$01							; Else
   863 36C0 84 85			sty Reg6							; Reg6 = 1
   864 36C2			Skip_Reg6
   865 36C2 0A				asl									; Multiply by 2
   866 36C3 85 84			sta Reg5
   867
   868 				; Now move into that line in VRAM based on the X-Position
   869 36C5 18				clc									; Prepare to add
   870 36C6 A5 80			lda Reg1							; X_Pos_L
   871 36C8 65 83			adc Reg4							; Add Adr0
   872 36CA 85 83			sta Reg4							; Store it
   873 36CC A5 81			lda Reg2							; X_Pos_H
   874 36CE 65 84			adc Reg5							; Add Adr1
   875 36D0 85 84			sta Reg5							; Store it
   876 36D2 A9 00			lda #$00
   877 36D4 65 85			adc Reg6							; Account for overflow
   878 36D6 85 85			sta Reg6							; Store Adr2
   879
   880 				; Set Adr 2 depending on which buffer we are writing to
   881 36D8 18				clc									; Prepare to add
   882 36D9 A5 86			lda Reg7
   883 36DB 65 85			adc Reg6							; Carry flag weill NEVER be set, as value will only ever be 0-1 or 2-3
   884 36DD 85 85			sta Reg6
   885 36DF			Calculate_200_End						; This takes on average $37(55) cycles, code is $22(34) bytes TODO: Calculate new cycle time based on code to handle double buffering
   886 36DF 68				pla
   887 36E0 8D 5F D6			sta VBXE_MA_BSEL					; Restore to initial value
   888
   889 36E3 60				rts
   890
   891 				;-----------------------------------------------------------------------------
   892 				; Setup_DisplayList - Points ANTIC to a Display List that will be in VBXE RAM
   893 				;-----------------------------------------------------------------------------
   894 36E4			Setup_DisplayList
   895 36E4 AD 2F 02			lda SDMCTL
   896 36E7 48				pha									; Save it
   897
   898 36E8 A9 00			lda #$00							; Turn off ANTIC DMA
   899 36EA 8D 2F 02			sta SDMCTL							; To safely set SDLSTL
   900
   901 36ED A9 00			lda <Display_List
   902 36EF 8D 30 02			sta SDLSTL
   903 36F2 A9 59			lda >Display_List
   904 36F4 8D 31 02			sta SDLSTH
   905
   906 36F7 68				pla									; Restore it
   907 36F8 8D 2F 02			sta SDMCTL
   908
   909 36FB 60				rts									; Go Home
   910
   911 				;-----------------------------------------------------------------------------
   912 				; Generate_Colour_Map
   913 				; This will generate the 9600 byte colour map used by the VBXE
   914 				;-----------------------------------------------------------------------------
   915 36FC			Generate_Colour_Map
   916 36FC A9 00			lda #$00
   917 36FE 85 88			sta Ptr_Lo
   918 3700 A9 06			lda #$06
   919 3702 85 89			sta Ptr_Hi							; Initialize destination pointer to $0600
   920
   921 3704 A9 01			lda #$01
   922 3706 85 80			sta Reg1							; Running colour accumulator
   923
   924 3708 A2 00			ldx #$00							; Object counter (0-15)
   925 370A			obj_loop
   926 370A A0 00			ldy #$00							; Row counter (0-14)
   927 370C			row_loop
   928 370C A9 00			lda #$00							; Default: blank row
   929 370E C0 00			cpy #$00
   930 3710 F0 08			beq store_colour
   931 3712 C0 0E			cpy #$0E
   932 3714 F0 04			beq store_colour
   933 3716 A5 80			lda Reg1							; Non-blank row: use accumulator
   934 3718 E6 80			inc Reg1
   935 371A			store_colour
   936 371A 91 88			sta (Ptr_Lo),Y
   937
   938 371C C8				iny
   939 371D C0 0F			cpy #$0F							; 15 rows per object
   940 371F D0 EB			bne row_loop
   941
   942 				; Advance pointer by 15 to next object's base
   943 3721 A5 88			lda Ptr_Lo
   944 3723 18				clc
   945 3724 69 0F			adc #$0F
   946 3726 85 88			sta Ptr_Lo
   947 3728 90 02			bcc no_carry
   948 372A E6 89			inc Ptr_Hi
   949 372C			no_carry
   950 372C E8				inx
   951 372D E0 10			cpx #$10							; 16 objects
   952 372F D0 D9			bne obj_loop
   953
   954 				; ; For debugging, skip all the 0 entries
   955 				; 	ldx #$EF
   956 				; Generate_Colour_Map_L1
   957 				; 	txa									; Set $600-$6EF equal to
   958 				; 	sta $0600,x							; $00-$EF
   959 				; 	dex
   960 				; 	bne Generate_Colour_Map_L1
   961 				; 	lda #$00
   962 				; 	sta $0600							; Pickup the final save
   963
   964 3731 20 68 36			jsr Setup_Cmap1						; Setup the Palette & Priority bits
   965 3734 20 38 37			jsr Setup_Colours
   966
   967 3737 60				rts
   968
   969 				;-----------------------------------------------------------------------------
   970 				; Setup_Colours
   971 				; Uses the temp table at $600 to setup the Attribute Colour Map
   972 				;-----------------------------------------------------------------------------
   973 3738			Setup_Colours
   974 				; Turn on VBXE window so we can modify the BCB
   975 3738 A9 80			lda #$80							; Copy some data into VBXE address space (XDL, Blitter control blocks (BCB))
   976 373A 8D 5F D6			sta VBXE_MA_BSEL
   977
   978 373D A2 00			ldx #$00							; Prepare to loop
   979 373F			Setup_Colours_L1
   980 373F BD 00 06			lda $600,x							; Get the colour
   981 3742 8D 64 25			sta VBXE_WINDOW+$554+$10			; BLT_SETUP_CMAP_2 starts at $0554 in VBXE bank 0, XOR Mask is offset $10
   982
   983 3745 20 86 36			jsr Setup_Cmap2						; Setup a row of colours
   984
   985 				; Now we must do a 24-bit addition to get the next Destination Address (offset 6,7,8)
   986 3748 18				clc
   987 3749 AD 5A 25			lda VBXE_WINDOW+$554+$06			; Dest Addr 2
   988 374C 69 28			adc #$28							; Advance by one line ($28 bytes/line)
   989 374E 8D 5A 25			sta VBXE_WINDOW+$554+$06			; Dest Addr 2
   990
   991 3751 AD 5B 25			lda VBXE_WINDOW+$554+$07			; Dest Addr 1
   992 3754 69 00			adc #$00
   993 3756 8D 5B 25			sta VBXE_WINDOW+$554+$07			; Dest Addr 1
   994
   995 3759 AD 5C 25			lda VBXE_WINDOW+$554+$08			; Dest Addr 0
   996 375C 69 00			adc #$00
   997 375E 8D 5C 25			sta VBXE_WINDOW+$554+$08			; Dest Addr 1
   998
   999 3761 E8				inx
  1000 3762 E0 EF			cpx #$EF
  1001 3764 D0 D9			bne Setup_Colours_L1
  1002
  1003 3766 60				rts
