   814 				;-----------------------------------------------------------------------------
   815 				; Setup_Cmap2 - Sets byte 2 for all cmap entries via blitter
   816 				;-----------------------------------------------------------------------------
   817 3686			Setup_Cmap2
   818 3686 A9 54			lda #BLT_SETUP_CMAP_2-BLT_BALL
   819 3688 8D 50 D6			sta VBXE_BL_ADR0					; Setup the blitter for memory fill operation
   820 368B A9 00			lda #$00
   821 368D 8D 52 D6			sta VBXE_BL_ADR2					; See the description of BCB at the end of this
   822 3690 A9 05			lda #$05							; Source
   823 3692 8D 51 D6			sta VBXE_BL_ADR1
   824 3695 A9 00			lda #$00
   825 3697			Setup_Cmap2_L1
   826 3697 AD 53 D6			lda VBXE_BLITTER_BUSY
   827 369A C9 00			cmp #$00
   828 369C D0 F9			bne Setup_Cmap2_L1					; Wait for blitter to finish
   829 369E A9 01			lda #$01
   830 36A0 8D 53 D6			sta VBXE_BLITTER_START				; Start the blit
   831 36A3 60				rts
