   285
   286 				; Do all the work
   287 3384 20 03 44			jsr music.play						; Play a frame of music
   288 3387 20 F4 33			jsr Set_Positions					; Update positions, bounce, write BCBs, blit all sprites
   289 338A 20 7F 35			jsr Flip_Screen						; Swap buffers
   290 338D 20 4A 36			jsr Clear_Screen					; Redraw background
   291
   292 				; Work done -wait for vertical synch before looping again
   293 3390			W_Synch_0
   294 3390 20 15 36			jsr Wait_For_Sync					; Wait for VSYNC, Q quits
   295 3393 A9 FF			lda #$FF
   296 3395 8D FC 02			sta CH
   297 3398 A9 00			lda #DBG_SINGLE_STEP
   298 339A F0 0F			beq Dont_Wait_Space_0
   299 339C			Wait_Space_0
   300 339C A9 00			lda #$00
   301 339E 85 4D			sta ATRACT							; Disable screensaver
   302 33A0 AD FC 02			lda CH
   303 33A3 C9 2F			cmp #$2F							; Press Q to quit
   304 33A5 F0 07			beq Exit
   305 33A7 C9 21			cmp #$21							; Press Space to start
   306 33A9 D0 F1			bne Wait_Space_0
   307 33AB			Dont_Wait_Space_0
   308 33AB 4C 80 33			jmp Main_Loop						; Animate forever
   309
   310 				; This is where we exit
   311 33AE			Exit
