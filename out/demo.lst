    47 				.zpvar Reg6				.byte			; Multi-Use Variables
    48 				.zpvar Reg7				.byte			; Multi-Use Variables
    49 				.zpvar Reg8				.byte			; Multi-Use Variables
    50 				.zpvar Ptr_Lo			.byte			; Lo byte of pointer
    51 				.zpvar Ptr_Hi			.byte			; Hi byte of pointer
    52 				.zpvar Do_Motion		.byte			; Allows pausing motion for the initial start
    53 				.zpvar Num_Sprites		.byte			; Keeps track of the number of sprites we are displaying
    54
    55 				; Non Page-0 Variables
