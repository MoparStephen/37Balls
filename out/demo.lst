   921 37A0 1A 27 27 27 27 34 + 	dta	$1A,$27,$27,$27,$27,$34,$34,$34,$34,$41,$41,$41,$41,$41,$41,$4E		; Objs $10-$1F
   922 37B0 4E 4E 4E 4E 4E		dta	$4E,$4E,$4E,$4E,$4E													; Objs $20-$24
