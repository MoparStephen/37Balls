    21 				;-----------------------------------------------------------------------------
    22 				; Structure Declarations
    23 				;-----------------------------------------------------------------------------
    24 				.struct Sprite
    25 = 0000				X_Pos_Frac			.byte			; Horizontal position (Fractional) sprite1
    26 = 0001				X_Pos_Lo			.byte			; Horizontal position sprite1
    27 = 0002				X_Pos_Hi			.byte			; Horizontal position sprite1 (Valid Values 0-319)
    28 = 0003				Y_Pos_Frac			.byte			; Vertical position (Fractional) sprite1
    29 = 0004				Y_Pos				.byte			; Vertical position sprite1 (valid values 0-239)
    30 = 0005				Delta_X_Sign		.byte			; X-Delta Sign (toggles betwen $00:Right, $FF:Left)
    31 = 0006				Delta_X_Frac		.byte			; Fractional X-Delta
    32 = 0007				Delta_X				.byte			; X-Delta (Valid Values) (+ = move right, - = move left)
    33 = 0008				Delta_Y_Sign		.byte			; Y-Delta Sign (toggles betwen $00:Down, $FF:Up)
    34 = 0009				Delta_Y_Frac		.byte			; Fractional Y-Delta
    35 = 000A				Delta_Y				.byte			; Y-Delta (Valid Values) (+ = move down, - = move up)
    36 				.ends
    37
