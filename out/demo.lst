   898 37C2 01 01 02 03 00 01 + 	dta $01,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03
   899 37D2 00 01 02 03 00 01 + 	dta $00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03
   900 37E2 00 01 02 03 00		dta $00,$01,$02,$03,$00
   901 37E7			Init_Delta_X_Frac
   902 37E7 00 40 80 C0 10 50 + 	dta $00,$40,$80,$C0,$10,$50,$90,$D0,$20,$60,$A0,$E0,$30,$70,$B0,$F0
   903 37F7 40 80 C0 00 50 90 + 	dta $40,$80,$C0,$00,$50,$90,$D0,$10,$60,$A0,$E0,$20,$70,$B0,$F0,$30
   904 3807 80 C0 00 40 90		dta $80,$C0,$00,$40,$90
   905 380C			Init_Delta_Y
   906 380C 06 02 03 00 01 02 + 	dta $06,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$01,$01,$02,$03,$00
   907 381C 01 02 03 00 01 02 + 	dta $01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00,$01,$02,$03,$00
   908 382C 01 02 03 00 01		dta $01,$02,$03,$00,$01
   909 3831			Init_Delta_Y_Frac
   910 3831 00 60 A0 E0 30 70 + 	dta $00,$60,$A0,$E0,$30,$70,$B0,$F0,$40,$80,$C0,$00,$50,$90,$D0,$10
   911 3841 60 A0 E0 20 70 B0 + 	dta $60,$A0,$E0,$20,$70,$B0,$F0,$30,$80,$C0,$00,$40,$90,$D0,$10,$50
   912 3851 A0 E0 20 60 B0		dta $A0,$E0,$20,$60,$B0
