   148 				;VBXE_Detect - detects VBXE FX core version 1.07 and above,
   149 				; and stores VBXE Base address in VBXEBase
   150 3139			VBXE_Detect
   151 3139 A9 00			lda	#0
   152 313B A2 D6			ldx	#$d6
   153 313D 8D 40 D6			sta	$d640			; make sure it isn't coincidence
   154 3140 AD 40 D6			lda	$d640
   155 3143 C9 10			cmp	#$10			; do we have major version here?
   156 3145 F0 15			beq	VBXE_Detected	; if so, then VBXE is detected
   157 3147 A9 00			lda	#0
   158 3149 E8				inx
   159 314A 8D 40 D7			sta	$d740			; no such luck, try other location
   160 314D AD 40 D7			lda	$d740
   161 3150 C9 10			cmp	#$10
   162 3152 F0 08			beq	VBXE_Detected
   163 3154 A2 00			ldx 	#0  		; not here, so not present or FX core version too low
   164 3156 86 92			stx	VBXEBase+1
   165 3158 86 91			stx	VBXEBase
   166 315A 38				sec
   167 315B 60				rts
   168 315C			VBXE_Detected:
   169 315C 86 92			stx	VBXEBase+1
   170 315E A9 00			lda	#0
   171 3160 85 91			sta	VBXEBase
   172 3162				vblda	VBXE_MINOR	; get core minor version
