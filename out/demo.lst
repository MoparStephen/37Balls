   581 353F 8A				txa
   582 3540 A8				tay
   583 3541 B9 FC 36			lda	Init_Delta_X_Frac,y
   584 3544 A0 06			ldy	#Spr_Delta_X_Frac
   585 3546 91 88			sta	(Ptr_Lo),y
   586
   587 3548 A9 00			lda	#$00							; Initially moving right
   588 354A A0 05			ldy	#Spr_Delta_X_Sign
   589 354C 91 88			sta	(Ptr_Lo),y
   590
   591 354E 8A				txa
   592 354F A8				tay
   593 3550 B9 21 37			lda	Init_Delta_Y,y
   594 3553 A0 0A			ldy	#Spr_Delta_Y
