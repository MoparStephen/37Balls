   318 				;-----------------------------------------------------------------------------
   319 				; Reverse_X - 2's complement negate of Delta_X_Sign:Delta_X:Delta_X_Frac
   320 				; Ptr_Lo/Ptr_Hi must point to the current Sprite struct
   321 				;-----------------------------------------------------------------------------
   322 33B8			Reverse_X
   323 33B8 38				sec
   324 33B9 A0 06			ldy	#Spr_Delta_X_Frac
   325 33BB A9 00			lda	#$00
   326 33BD F1 88			sbc	(Ptr_Lo),y
   327 33BF 91 88			sta	(Ptr_Lo),y
   328 33C1 A0 07			ldy	#Spr_Delta_X
   329 33C3 A9 00			lda	#$00
   330 33C5 F1 88			sbc	(Ptr_Lo),y
   331 33C7 91 88			sta	(Ptr_Lo),y
   332 33C9 A0 05			ldy	#Spr_Delta_X_Sign
   333 33CB B1 88			lda	(Ptr_Lo),y
   334 33CD 49 FF			eor	#$FF
   335 33CF 91 88			sta	(Ptr_Lo),y
   336 33D1 60				rts
   337
   338 				;-----------------------------------------------------------------------------
   339 				; Reverse_Y - 2's complement negate of Delta_Y_Sign:Delta_Y:Delta_Y_Frac
   340 				;-----------------------------------------------------------------------------
   341 33D2			Reverse_Y
   342 33D2 38				sec
   343 33D3 A0 09			ldy	#Spr_Delta_Y_Frac
   344 33D5 A9 00			lda	#$00
   345 33D7 F1 88			sbc	(Ptr_Lo),y
   346 33D9 91 88			sta	(Ptr_Lo),y
   347 33DB A0 0A			ldy	#Spr_Delta_Y
   348 33DD A9 00			lda	#$00
   349 33DF F1 88			sbc	(Ptr_Lo),y
   350 33E1 91 88			sta	(Ptr_Lo),y
   351 33E3 A0 08			ldy	#Spr_Delta_Y_Sign
   352 33E5 B1 88			lda	(Ptr_Lo),y
   353 33E7 49 FF			eor	#$FF
   354 33E9 91 88			sta	(Ptr_Lo),y
   355 33EB 60				rts
