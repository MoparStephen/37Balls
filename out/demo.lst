   400
   401 3369			blit_clear
   402 					; clear 496kB (leave bottom 16kB for the SVBXE.SYS driver)
   403 					; 496x16 zoom 8x8 clear blit (this takes 2 frames)
   404
   405 					;	dta e($00000)	; Source address
   406 					;	dta a($0000)	; Source step y
   407 					;	dta 0			; Source step x
   408 					;	dta e($7BFFF)	; Destination address
   409 					;	dta a(-$0F80)	; Destination step y (backwards 3968 bytes) - NOTE: this equals 496 * zoom factor of 8
   410 					;	dta -1			; Destination step x (backwards	1 byte)
   411 					;	dta a($01EF)	; Width-1  (495)	496 * 8 bytes wide
   412 					;	dta $0F			; Height-1 (15)		 16 * 8 bytes high
   413 					;	dta $00			; And mask (And mask equal to 0 so clear)
   414 					;	dta $00			; Xor mask (will be filled with xor mask)
   415 					;	dta $00			; Collision and mask
   416 					;	dta $77			; Zoom (BLT_ZOOMY = 7, BLT_ZOOMX = 7 so 8Y*8X)
   417 					;	dta $00			; Pattern feature
   418 					;	dta $00			; Control (Mode 0 with NEXT bit Cleared)
   419
   420 3369 00 00 00 00 00 00 + 	dta e($00000), a($0000), 0, e($7BFFF), a(-$0F80), -1, a($01EF), $0F, $00, $00, $00, $77, $00, $00
   421 337E			Clearing_Message
   422 337E 23 6C 65 61 72 69 + 	.sb 'Clearing VBXE RAM                '
   423
   424 				.endp
